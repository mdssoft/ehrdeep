# Core runtime
NODE_ENV=development
LOG_LEVEL=info

# MIS HTTP gateway (Cache routines via zWS)
MIS_SERVER_IP=127.0.0.1
MIS_SERVER_PORT=57772
MIS_AUTH_USERNAME=mis_user
MIS_AUTH_PASSWORD=mis_password
MIS_TIMEOUT_MS=30000
MIS_DOC_ENDPOINT=/ANONDOCS_MECRAG
MIS_CHUNK_LIMIT=100

# Storage
SQLITE_DB_PATH=./var/ehrdeep.db
VECTOR_DB_ENGINE=sqlite
VECTOR_DB_PATH=./var/vector.db
VECTOR_DIMENSION=1024
SQLITE_VEC_EXTENSION_PATH=
LANCEDB_DIR=./var/lancedb

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://localhost/ehrdeep
OPENROUTER_APP_NAME=ehrdeep
# Legacy shared key fallback (used if per-connection keys are not set)
OPENROUTER_API_KEY=
# Default connection: one model -> one connection -> one key
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_DEFAULT_BASE_URL=
OPENROUTER_DEFAULT_API_KEY=
# Analysis connection: one model -> one connection -> one key
OPENROUTER_ANALYSIS_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_ANALYSIS_BASE_URL=
OPENROUTER_ANALYSIS_API_KEY=
# Embedding connection: one model -> one connection -> one key
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_EMBEDDING_BASE_URL=
OPENROUTER_EMBEDDING_API_KEY=
OPENROUTER_TIMEOUT_MS=45000
OPENROUTER_MAX_RETRIES=2
ALLOW_LOCAL_EMBEDDING_FALLBACK=true

# Analysis tuning
SIMILARITY_TOP_K=12
CONTEXT_DOC_LIMIT=12

# ------------------------------------------------------------
# Optional: MIS proxy utilities (mis-proxy/*)
# ------------------------------------------------------------
# Public proxy
PROXY_BIND_HOST=0.0.0.0
PROXY_BIND_PORT=17800
PROXY_AGENT_KEYS_JSON={"local-mis":"agent-secret"}
PROXY_CLIENT_KEYS_JSON={"local-client":{"key":"client-secret","targets":["local-mis"]}}
PROXY_MAX_BODY_BYTES=1048576
PROXY_MAX_QUEUE_PER_TARGET=1000
PROXY_REQUEST_TIMEOUT_MS=20000
PROXY_LONG_POLL_TIMEOUT_MS=25000
PROXY_AGENT_LIVENESS_MS=60000
PROXY_RATE_LIMIT_WINDOW_MS=1000
PROXY_RATE_LIMIT_IP_MAX=100
PROXY_RATE_LIMIT_CLIENT_MAX=200

# MIS-side agent
PROXY_SERVER_URL=http://127.0.0.1:17800
PROXY_TARGET_ID=local-mis
PROXY_AGENT_ID=agent-1
PROXY_AGENT_KEY=agent-secret
MIS_LOCAL_BASE_URL=http://127.0.0.1:57772
PROXY_AGENT_POLL_RETRY_MS=200
PROXY_AGENT_ERROR_BACKOFF_MS=1000
PROXY_AGENT_HEARTBEAT_MS=10000
PROXY_AGENT_REQUEST_TIMEOUT_MS=30000
PROXY_AGENT_MIS_MAX_ATTEMPTS=5
PROXY_AGENT_MIS_RETRY_DELAY_START_MS=5000
PROXY_AGENT_MIS_RETRY_DELAY_MAX_MS=60000
PROXY_AGENT_SUCCESS_CACHE_TTL_MS=600000
PROXY_AGENT_SQLITE_PERSISTENCE_ENABLED=false
PROXY_AGENT_SQLITE_DB_PATH=./var/mis-proxy-agent.sqlite

# Client-side gateway
PROXY_GATEWAY_HOST=127.0.0.1
PROXY_GATEWAY_PORT=17801
PROXY_CLIENT_ID=local-client
PROXY_CLIENT_KEY=client-secret
PROXY_GATEWAY_ALLOWLIST=127.0.0.1,::1
PROXY_GATEWAY_MAX_BODY_BYTES=1048576
