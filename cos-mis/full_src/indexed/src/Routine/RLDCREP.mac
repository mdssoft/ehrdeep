RLDCREP ; Отчеты для П-ки Минэкономразвития [ 12/16/2011  7:13 PM ]
STP2N(NAZ) ; Приложение 2 только из назначений
 N NIB
 S NIB=$$NIB^INAZN(NAZ)
 G STP2+1
STP2(NIB,NAZ) ; Приложение 2
 N I,W,OTD,VR,KX,DT,SUS,SUi,UX,R,F,CEN,CNT,SUM,DS,DE,DV,VRS
 N @$$NEWVAR^IUSL
 S NAZ=$G(NAZ)
 D OWF^RWU(".xml")
 F I=1:1:10 D WC^RWU(CR_$E($T(STP2R1+I),3,999))
 D WTAGC^RWU("nib",NIB)
 D WTAGC^RWU("fiof",$$GET^IPAC(NIB,"fiof"))
 D WTAGC^RWU("fioi",$$GET^IPAC(NIB,"fioi"))
 D WTAGC^RWU("fioo",$$GET^IPAC(NIB,"fioo"))
 F I=1:1:20 D WC^RWU(CR_$E($T(STP2R2+I),3,999))
 S DS=+$H-3
 I $G(NAZ)'="" S DS=$$fromDT^INAZN(NAZ) S:DS="" DS=+$H-3
 S DE=DS+3
 S VR=$$KDR^IUSER(),OTD=$$OTD^IKADRY(VR)
 S DV=$$GET^YNDOG($$GET^IPAC(NIB,"stc",DE),"dvid")
 S W="134|20|40",F="|c|",SUM=0
 D TAB^ISTREP("Наименование услуги|Стоимость|Исполнитель",W,"f")
 F DT=DS-1:1:DE S KX="" F  S KX=$O(^PNF(NIB,DT,KX)) Q:KX=""  D
 .S OT=$P(KX,"|",2)
 .I OT'=OTD,'$$IsOTD^IKADRY($P(^(KX),"|",6),OTD,DE) q  ; кто ввел из OTD
 .S VR=$P(KX,"|",1),ID=$P(KX,"|",3)
 .D GET^IUSL(VR,DT,OT,ID)
 .Q:STAT="d"!(STAT="w")!(STAT="")!(STAT>3)
 .S FLG="|"_$G(FLG)_"|"
 .I DV'=3,'(STAT=2!(FLG["|kss|")!(FLG["|nop|")) Q  ; для страх. только касса
 .S SUS=$$GETPL^IUSL(VR,DT,OT,ID,"s"),SUi=2
 .S UX="" F  S UX=$O(UL(UX)) Q:UX=""  D
 ..S CNT=$S(UX="":"",1:UL(UX))
 ..S CEN=$S(SUS'=""&(SUS'["|"):SUS,SUS'="":$P(SUS,"|",SUi),1:$$USUM^IUSL(DT,UX,CNT))
 ..S SUi=SUi+1,SUM=SUM+CEN
 ..S R=$$NAMEH^IPRICE(UX,PRC,DT)_"|"_CEN_"|"_$$FIOSH^IKADRY(VR)
 ..D TLN^ISTREP(R,W,"","","tlrb",F)
 F I=1:1:2 D WC^RWU(CR_$E($T(STP2R3+I),3,999))
 D WC^RWU(CR_"<f>$moneytowords:"_SUM_":руб.:коп.</f></p>")
 F I=1:1:7 D WC^RWU(CR_$E($T(STP2R4+I),3,999))
 D C^RWU
 Q
STP2R1 ; 28
