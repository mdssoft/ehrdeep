STP1N(ID) ; Приложение 1 (печать из назначений)
 N A,P,U,X,NIB,LST,S,SS,DT
 S DT=$$fromDT^INAZN(ID)
 D NLSTsum^NNAZU(ID)
 D OWF^RWU(".xml")
 D W^RWU(^PP(0,1))
 D WC^RWU("<streport nm=""Приложение №1 к договору стационара""><data>")
 D WTAG^RWU("num",ID)
 D WTAG^RWU("nib",NIB)
 D WTAGC^RWU("fio",$$FIO^IPAC(NIB))
 D WTAGC^RWU("comm",$G(^NAZ(ID,"c")))
 S SS=0,(A,X)="" F  S X=$O(LST(X)) Q:X=""  D
 .S U=$P(X,"|",1),P=$P(X,"|",2),S=LST(X,1),SS=SS+S
 .S A=$S(A="":"",1:A_CR)_$$NAMEH^IPRICE(U,P,DT)_"|"_S
 D WTAGC^RWU("tab",A)
 D WTAGC^RWU("summ",SS)
 D W^RWU("</data></streport>")
 D C^RWU
 Q
