 ; <td>АВАНС</td>
 ; <td>ВСЕГО</td>
 ; <td>ФИЗЛИЦА</td>
 ; <td>ФАКТ</td>
 ; <td>АВАНС</td>
 ; <td>СРЕДНЯЯ</td>
 ; <td>ФИЗЛИЦА</td>
 ; <td>ФАКТ</td>
 ; <td>АВАНС</td>
 ; <td>ВСЕГО</td>
 ; <td>ФИЗЛИЦА</td>
 ; <td>ФАКТ</td>
 ; <td>АВАНС</td>
 ; <td>ФИЗЛИЦА</td>
 ; <td>ФАКТ</td>
 ; <td>АВАНС</td>
 ; <td>ФИЗЛИЦА</td>
 ; <td>ФАКТ</td>
 ; <td>АВАНС</td>
 ;</tr>
REGIPROC 
 N X,T
 S X="0/По отделениям#2/По врачам#4/По специальностям#5/Только специальности#6/Специальность+врач"_$S(+$$FR^I():"#3/По филиалам",1:"")
 S X=",d,Начальный период,d,Конечный период,t@string:"_X_",Отображать отчет,t@string:0/Все#1/Поликлиника#2/Стоматология#3/Стационар,Подразделения,t@string:0/Нет#1/Да,Расчет по всем видам договоров,t@string:1/Да#0/Нет#3/Только абонементы#2/Отдельно,Учитывать абонементы как аванс"
 S T="Посещаемость и обращаемость"
 S ^IPROC("Отчеты ЛПУ",T,"Сводка по посещаемости и загрузке")="DO_RLPUPZ,3,7"_X_",t@string:0/Нет#1/Да,Исключить нулевые услуги"
 S ^IPROC("Отчеты ЛПУ",T,"Таблица по посещаемости и загрузке")="DOTAB_RLPUPZ,1,8"_X_",t@string:0/В процентах#1/Проценты по факту#2/Десятично в минутах,Представление загрузки,t@string:0/Нет#1/Да,Исключить нулевые услуги,l,8,1"
 Q
