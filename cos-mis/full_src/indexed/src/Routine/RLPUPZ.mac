 ; <td colspan="4"><div align="center">ПОСЕЩАЕМОСТЬ</div></td>
 ; <td colspan="4"><div align="center">ОКАЗАНО УСЛУГ</div></td>
 ; <td colspan="3"><div align="center">СРЕДНИЙ ЧЕК ПО ПАЦИЕНТУ</div></td>
