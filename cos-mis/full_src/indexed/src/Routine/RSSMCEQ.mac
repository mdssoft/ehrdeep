post ; постобработка
 S I1="" F  S I1=$O(TABLE(I1)) Q:I1=""  D
 .S I2="" F  S I2=$O(TABLE(I1,I2)) Q:I2=""  D
 ..S X1=$G(TABLE(I1,I2,1)),X3=$G(TABLE(I1,I2,3))
 ..S EQI=$S('MODE:I2,1:I1),LP=$S('MODE:I1,1:I2)
 ..S X4=$G(^BUF($J,"usum",EQI))
 ..S:EQI=1 X3=X3*0.5
 ..S:EQI=2 X3=X1*DCNT
 ..S:EQI=3 X3=X1*DCNT
 ..S:EQI=5 X3=X3*0.1
 ..S:EQI=6 X3=24*X1*DCNT ;X3
 ..S:EQI=7 X3=24*X1*DCNT ;X3
 ..S:EQI=8 X3=X3*0.25
 ..S:EQI=9 X3=X3*0.05
 ..S:EQI=10 X3=X3*0.15
 ..S:EQI=11 X3=X3*5*0.6
 ..S:EQI=12 X3=X3*5
 ..S:EQI=13 X3=24*X1*DCNT ;X3
 ..S:EQI=14 X3=24*X1*DCNT ;X3
 ..S:EQI=15 X3=X3*5
 ..S:EQI=16 X3=X3*5
 ..S:EQI=17 X3=X3
 ..S:EQI=18 X3=X3
 ..S:EQI=19 X3=X3*2
 ..S:EQI=20 X3=X3*0.25
 ..S:EQI=21 X3=X3
 ..S:EQI=22 X3=X3*0.5
 ..S:EQI=23 X3=X3*0.1
 ..S:EQI=24 X3=24*X1*DCNT,X3=$S(LP=3:X3*0.75,1:X3) ;X3
 ..S:EQI=25 X3=$S(LP=3:X3*0.25,1:0)
 ..S:EQI=26 X3=X3*0.1
 ..S X3=+$J(X3,"",2),X4=+$J(X3*X4,"",2)
 ..S X5=$G(TABLE(I1,I2,5))
 ..S TABLE(I1,I2,2)=$S(X3:100*$J(X5/X3,"",4),1:0)
 ..S TABLE(I1,I2,3)=X3
 ..S TABLE(I1,I2,4)=X4
 ..S TABLE(I1,I2,7)=X4-$G(TABLE(I1,I2,6))
 ..Q:'VTP
 ..S DGT="" F  S DGT=$O(TABLEV(I1,I2,DGT)) Q:DGT=""  D 
 ...S X4=$G(^BUF($J,"usum",EQI))
 ...S X3=$G(TABLEV(I1,I2,DGT,3))
 ...S:EQI=1 X3=X3*0.5
 ...S:EQI=2 X3=0 ;X1*DCNT
 ...S:EQI=3 X3=0 ;X1*DCNT
 ...S:EQI=5 X3=X3*0.1
 ...S:EQI=6 X3=0 ;24*X1*DCNT ;X3
 ...S:EQI=7 X3=0 ;24*X1*DCNT ;X3
 ...S:EQI=8 X3=X3*0.25
 ...S:EQI=9 X3=X3*0.05
 ...S:EQI=10 X3=X3*0.15
 ...S:EQI=11 X3=X3*5*0.6
 ...S:EQI=12 X3=X3*5
 ...S:EQI=13 X3=0 ;24*X1*DCNT ;X3
 ...S:EQI=14 X3=0 ;24*X1*DCNT ;X3
 ...S:EQI=15 X3=X3*5
 ...S:EQI=16 X3=X3*5
 ...S:EQI=17 X3=X3
 ...S:EQI=18 X3=X3
 ...S:EQI=19 X3=X3*2
 ...S:EQI=20 X3=X3*0.25
 ...S:EQI=21 X3=X3
 ...S:EQI=22 X3=X3*0.5
 ...S:EQI=23 X3=X3*0.1
 ...S:EQI=24 X3=0 ;24*X1*DCNT,X3=$S(LP=3:X3*0.75,1:X3) ;X3
 ...S:EQI=25 X3=$S(LP=3:X3*0.25,1:0)
 ...S:EQI=26 X3=X3*0.1
 ...S X3=+$J(X3,"",2),X4=+$J(X3*X4,"",2)
 ...S TABLEV(I1,I2,DGT,1)=X1
 ...S X5=$G(TABLEV(I1,I2,DGT,5))
 ...S TABLEV(I1,I2,DGT,2)=$S(X3:100*$J(X5/X3,"",4),1:0)
 ...S TABLEV(I1,I2,DGT,3)=X3
 ...S TABLEV(I1,I2,DGT,4)=X4
 ...S TABLEV(I1,I2,DGT,7)=X4-$G(TABLEV(I1,I2,DGT,6))
 
 Q
proc(VR,OT,DT,ID) ; процедура подсчета
 Q:"wd"[$$GETSTAT^IUSL(VR,DT,OT,ID) 
 
 S ULX=$$GETUSLS^IUSL(VR,DT,OT,ID) Q:ULX=""
 S ULC=$P(ULX,"*",2) S:ULC="" ULC=1
 S ULX=$P(ULX,"*",1) Q:ULX=""
 
 S EQI=$G(^BUF($J,"ue",ULX))
 S SP=$$GETSP^IUSL(VR,DT,OT,ID) Q:SP="" 
 S:VTP DGT=$$GETDGT^IRPUSL($$GETDGN^IUSL(VR,DT,OT,ID),DT)
 
 S LPU=$$GETLPU^IUSL(VR,DT,OT,ID)
 D:EQI fcalc
 
 I 'EQI,'SP Q
 I '$D(SPX(+SP)),'$D(EQX(+EQI)) Q 
 D GET^IUSL(VR,DT,OT,ID,1)
 Q:'$D(UL)
 S DIA=$G(DIA)
 S CNT=UL($O(UL(""))) S:CNT="" CNT=1
 S PERV=$$IsFPOS^IUSL(NI,OT,VR,DT,ID)
 ; 1
 I $D(SPX(SP,1)),'$D(^BUF($J,"tmp",1,NI)) S ^(NI)="" d add(LPU,1,1)
 I VTP,$D(SPX(SP,1)),'$D(^BUF($J,"tmpt",DGT,1,NI)) S ^(NI)="" d addT(LPU,1,1)
 ; 5
 I $D(SPX(SP,5)),'$D(^BUF($J,"tmp",5,NI)) S ^(NI)="" d add(LPU,5,1)
 I VTP,$D(SPX(SP,5)),'$D(^BUF($J,"tmpt",DGT,5,NI)) S ^(NI)="" d addT(LPU,5,1)
 ; 6
