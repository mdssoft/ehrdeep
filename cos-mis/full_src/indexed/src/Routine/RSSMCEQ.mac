add(X1,X2,V) 
 S:MODE TABLE(X2,X1,3)=$G(TABLE(X2,X1,3))+V
 S:'MODE TABLE(X1,X2,3)=$G(TABLE(X1,X2,3))+V
 Q
addT(X1,X2,V) 
 S:MODE TABLEV(X2,X1,DGT,3)=$G(TABLEV(X2,X1,DGT,3))+V
 S:'MODE TABLEV(X1,X2,DGT,3)=$G(TABLEV(X1,X2,DGT,3))+V
 Q
fcalc ; подсчет по факту
 S X2=EQI
 S X1=LPU
 S:MODE X2=LPU,X1=EQI ; перевернуть
 S X3=$$GETSUM^IUSL(VR,DT,OT,ID)
 S TABLE(X1,X2,5)=$G(TABLE(X1,X2,5))+ULC
 S TABLE(X1,X2,6)=$G(TABLE(X1,X2,6))+X3
 Q:'VTP
 S TABLEV(X1,X2,DGT,5)=$G(TABLEV(X1,X2,DGT,5))+ULC
 S TABLEV(X1,X2,DGT,6)=$G(TABLEV(X1,X2,DGT,6))+X3
 Q
REGIPROC 
 S ^IPROC("ССМЦ","Выручка по оборудованию")="DO_RSSMCEQ,1,5,d,Дата отчета,d,Дата по,t@string:0/По клиникам#1/По оборудованию,Вид отчета,t@string:0/Обычный#1/По видам договоров,Формат,t@storage:lpu,Филиал"
 Q
