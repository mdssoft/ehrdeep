RSSMCEQ ; Отчет по оборудованию [ 12/12/2016  11:19 PM ]
DO(DS,DE,MODE,VTP,LPUX) 
 ; MODE - по клиникам\по оборудованию
 ; VTP - с раскладкой по видам договоров
 N SPX,DIAX,EQX,EQLN,EQTXT,TABLE,TABLEV,I1,I2,EQ,A,R,I,C,J,K,X1,X2,X3,X4
 N ULX,ULC,DGL,DGT,EQI,PERV,CNT,DCNT
 S DS=$$DIH^DTUTL(DS),DE=$$DIH^DTUTL(DE),DCNT=DE-DS+1
 K ^BUF($J)
 D init
 D tmpdb
 D ITERATE^IUSLD("proc^RSSMCEQ(VR,OT,DT,ID)",DS,DE,,,LPUX)
 D post
 
 D OWF^RWU(".txt")
 D WC^RWU("Оборудование|Единиц|Загрузка|План|План|Факт|Факт|Недополученна;")
 D WC^RWU(CR_$$TXTP^DTUTL(DS,DE)_"|оборуд.|оборуд.%|Услуг|Выручка|Услуг|Выручка|Выручка")
 S I1="" F  S I1=$O(TABLE(I1)) Q:I1=""  D
 .S X1=$S('MODE:$$NAME^ICONTR(I1),1:$G(EQTXT(I1))) ; ??
 .D WC^RWU(CR_X1)
 .S I2="" F  S I2=$O(TABLE(I1,I2)) Q:I2=""  D
 ..S R=$S(MODE:$$NAME^ICONTR(I2),1:EQTXT(I2))
 ..F I=1:1:7 S R=R_"|"_$TR($G(TABLE(I1,I2,I)),".",",")
 ..D WC^RWU(CR_R)
 ..Q:'VTP
 ..S DGT="" F  S DGT=$O(TABLEV(I1,I2,DGT)) Q:DGT=""  D
 ...S R=" - "_$$NAME^ISPRAV("dvid",DGT)
 ...F I=1:1:7 S R=R_"|"_$TR($G(TABLEV(I1,I2,DGT,I)),".",",")
 ...D WC^RWU(CR_R)
 D C^RWU
 K ^BUF($J)
 Q
tmpdb 
 S I="" F  S I=$O(^EQUIP(I)) Q:I=""  D
 .S X1=0,X2=0,X3=$G(EQLN(I)) Q:'X3 
 .S C="" F  S C=$O(^EQUIP(I,"usl",C)) Q:C=""  D
 ..S ^BUF($J,"ue",C)=X3
 ..S X1=X1+1,X2=X2+$$PRICE^IPRICE(C,1)
 .S:X1 ^BUF($J,"usum",X3)=+$J(X2/X1,"",2) ; стоим. усл. на оборуд.
 
 S L="" F  S L=$O(^PLPU(L)) Q:L=""  D:LPUX=""!(LPUX=L)
 .S X1="" F  S X1=$O(^PLPU(L,X1)) Q:X1=""  D
 ..S X2="" F  S X2=$O(^PLPU(L,X1,X2)) Q:X2=""  D
 ...S C="" F  S C=$O(^PLPU(L,X1,X2,"cab",C)) Q:C=""  D
 ....S I="" F  S I=$O(^PLPU(L,X1,X2,"cab",C,"eq",I)) Q:I=""  D
 .....S R=^(I),J=$P(R,"|",1),K=$P(R,"|",2) S:K="" K=1
 .....Q:J=""  ; no dev
 .....S X3=$G(EQLN(J)) Q:X3="" 
 .....S X4=$G(^BUF($J,"usum",X3))
 .....S:'MODE TABLE(L,X3,1)=$G(TABLE(L,X3,1))+K,TABLE(L,X3,4)=X4
 .....S:MODE TABLE(X3,L,1)=$G(TABLE(X3,L,1))+K,TABLE(X3,L,4)=X4
 Q
init 
