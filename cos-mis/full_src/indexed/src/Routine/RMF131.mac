RMF131 ; Форма 131 [ 01/13/2022  5:05 PM ]
DO(DS,DE) 
 N ARR,NI,DT,AG,PL,DG,PI,X,K,G,RXX,XX
 N LNRUN,UER,F2,F3,F4
 S DS=$$DIH^DTUTL(DS),DE=$$DIH^DTUTL(DE)
 K ^BUF($J,13)
 S ARR("year")=$$YEAR^DTUTL(DE)
 S ARR("lpuname")=$$^I("iname")
 S DG=692 ; OMS
 D init
 S LNRUN="psc^RMF131"
 S NI="" F  S NI=$$NEXT^IPAC(NI,"stc",DG) Q:NI=""  D
 .S PI=$$PIDXN^IPAC(NI,DG,DS) Q:PI=-1 
 .S AG=$$AGE^IPAC(NI,DS)
 .S X=$$ageidx(AG)
 .S K="cnt0"_X
 .S ARR(K_3)=$G(ARR(K_3))+1
 .S G=$$GET^IPAC(NI,"pol",DS)
 .I G=1 S ARR(K_7)=$G(ARR(K_7))+1
 .I G=2 S ARR(K_11)=$G(ARR(K_11))+1
 .S DT=$O(^PROFP(NI,"pat",DS-1)) Q:DT=""  Q:DT>DE 
 .Q:$G(^PROFP(NI,"pat",DT))'=38 
 .S ARR(K_4)=$G(ARR(K_4))+1
 .I G=1 S ARR(K_8)=$G(ARR(K_8))+1
 .I G=2 S ARR(K_12)=$G(ARR(K_12))+1
 .D DOSC^NPACSC(NI,DS,DE,0) K UER
 
 D summ
 
 S NI="" F  S NI=$O(^PROFP(NI)) Q:NI=""  D
 .S DT=$O(^PROFP(NI,"pat",DS-1)) Q:DT="" 
 .Q:DT>DE 
 .Q:$G(^PROFP(NI,"pat",DT))'=38 
 .S AG=$$AGE^IPAC(NI,DT)
 K ^BUF($J,13)
 D MAKE^IDOCGEN("f131.docx","ARR")
 Q
ageidx(V) 
 Q:V>75 7
 Q:V>64 6
 Q:V>59 5
 Q:V>54 4
 Q:V>39 3
 Q:V>34 2
 Q:V>17 1
 Q 0
psc 
 S PAT=$$FLinFL^TXTU(FLG,1) ; выявлен впервые
 S DIA=$G(DIA)
 S U="" F  S U=$O(UL(U)) Q:U=""  D
 .I $D(F2(U)) S RXX=F2(U) F J=1:1:$L(RXX,"|") D
 ..S XX=$P(RXX,"|",J)
 ..S ARR("t2"_XX)=$G(ARR("t2"_XX))+1
 ..S:PAT ARR("t2"_XX_"d")=$G(ARR("t2"_XX_"d"))+1
 .I $D(F3(U)) S RXX=F3(U) F J=1:1:$L(RXX,"|") D
 ..S XX=$P(RXX,"|",J)
 ..S ARR("t3"_XX_"b")=$G(ARR("t2"_XX_"b"))+1
 ..S:PAT ARR("t3"_XX_"e")=$G(ARR("t3"_XX_"e"))+1
 
 ; TODO - один диаг на пациента или уточнен
 ; 65 + 60 - возраст трудоспособности
 I DIA'="",$D(F4(DIA)) D
 .S XX=F4(DIA),K="t4"_XX
 .S ARR(K_"a")=$G(ARR(K_"a"))+1
 .I G=1 S ARR(K_"d")=$G(ARR(K_"d"))+1 
 .I G=2 S ARR(K_"g")=$G(ARR(K_"g"))+1
 .I G=1,AG<66 S ARR(K_"e")=$G(ARR(K_"e"))+1,ARR(K_"b")=$G(ARR(K_"b"))+1 
 .I G=1,AG>65 S ARR(K_"f")=$G(ARR(K_"f"))+1,ARR(K_"c")=$G(ARR(K_"c"))+1
 .I G=2,AG<61 S ARR(K_"h")=$G(ARR(K_"h"))+1,ARR(K_"b")=$G(ARR(K_"b"))+1 
 .I G=2,AG>60 S ARR(K_"i")=$G(ARR(K_"i"))+1,ARR(K_"c")=$G(ARR(K_"c"))+1
 
 Q
init 
 S F2("B01.047.001.7")="01|02|03|06|07|18|19|201|202"
 S F2("A09.05.026")="04"
