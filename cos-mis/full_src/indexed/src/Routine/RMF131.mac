 S F3("В01.047.001.7")=14
 S F3("В01.027.001")=15
 
 S F4("E78")="01"
 S F4("R73.9")="02"
 S F4("Z72.0")="03"
 S F4("Z72.4")="04"
 S F4("R63.5")="05"
