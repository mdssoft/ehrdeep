 S F4("Z82.4")=10
 S F4("Z83.2")=11
 S F4("Z80.0")=12
 S F4("Z80.9")=13
 S F4("Z82.5")=14
 S F4("Z83.3")=15
 S F4("R54")=18
 Q
summ 
 N L,I,X,X1,X2,X3,X4,X5,X6,SS
 ; T1001
 F I=3:1:14 D
 .F L=1:1:7 S ARR("cnt08"_I)=$G(ARR("cnt08"_I))+$G(ARR("cnt0"_L_I))
 
 Q
REGIPROC 
 S ^IPROC("Медстатистика","Форма 131")="DO_RMF131,15,2,d,Начальная дата периода,d,Конечная дата периода"
