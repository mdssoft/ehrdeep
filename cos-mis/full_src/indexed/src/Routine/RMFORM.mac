 S ^IPROC("Медстатистика","Ф-30")="F30_RMFORM,8,2,d,Начальная дата периода,d,Конечная дата периода,,,,/mforms/f30.xls"
 
 S ^IPROC("Медстатистика","Форма 12")="F12_RMFORM,15,2,d,Начальная дата периода,d,Конечная дата периода"
 S ^IPROC("Медстатистика","Форма 57")="F57_RMFORM,15,2,d,Начальная дата периода,d,Конечная дата периода"
 Q
