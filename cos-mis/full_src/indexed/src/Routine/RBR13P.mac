RBR13P ; Отчеты Бранчевский раздел 1.3x-1.4x [ 10/04/2018  3:49 PM ]
F130(DS,DE) 
 N REZ,LP,I
 S DS=$$DIH^DTUTL(DS),DE=$$DIH^DTUTL(DE)
 S REZ("sheets","list","A6")=$$MNNM^DTUTL($$MONTH^DTUTL(DS))
 S I=0
 S LP="" F  S LP=$O(^DSH(LP)) Q:LP=""  D
 .S REZ("sheets","list","A"_(10+I))=$$NAME^ICONTR(LP)
 .S I=I+1
 D MAKE^IDOCGEN("1_30.xlsx","REZ","xlsx")
 Q
F131(DS,DE) 
 N REZ
 S DS=$$DIH^DTUTL(DS),DE=$$DIH^DTUTL(DE)
 S REZ("sheets","list","A7")=$$YEAR^DTUTL(DS)_" г"
 D MAKE^IDOCGEN("1_31.xlsx","REZ","xlsx")
 Q
F132(DS,DE) 
 N REZ,LPU
 S LPU=3
 S DS=$$DIH^DTUTL(DS),DE=$$DIH^DTUTL(DE)
 S REZ("sheets","list","A5")=$$NAME^ICONTR(LPU)_" за "_$$YEAR^DTUTL(DS)_" г"
 D MAKE^IDOCGEN("1_32.xlsx","REZ","xlsx")
 Q
