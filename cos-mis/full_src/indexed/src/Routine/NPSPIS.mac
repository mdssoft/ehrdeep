 S A=A_"СРОК ПО"_CR
 S A=A_"ДОГОВОР"_CR
 S A=A_"ПРОГРАММА"_CR
 S A=A_"ОФОРМЛЕН"_CR
 S A=A_"ДАТА.ОФОРМЛ."_CR
