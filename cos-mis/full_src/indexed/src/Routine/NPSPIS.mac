MKCOLUMN(PLNM,NMPL) ; Массив по столбцам - прямой/обратный
 N P,R,I
 S R="polis|dog_from|dog_to|stc|prog|ofor|dofor|savedate"
 S P="ПОЛИС|СРОК С|СРОК ПО|ДОГОВОР|ПРОГРАММА|ОФОРМЛЕН|ДАТА.ОФОРМЛ.|ДАТА ИЗМЕНЕНИЯ"
 F I=1:1:8 S:PLNM'="" @PLNM@($P(R,"|",I))=$P(P,"|",I) S:NMPL'="" @NMPL@($P(P,"|",I))=$P(R,"|",I)
 Q
PRBYDGN(DGN,DT) ; Программы по договору
 N R,X,A,Z
 S DT=$$DIH^DTUTL($G(DT))
 S R=$$GET^IINSC(DGN,"progs",DT)
 S:$E(R,$L(R))="|" $E(R,$L(R))=""
 S X=$$GET^IINSC(DGN,"progsa",DT)
 S R=$S($L(X)&$L(R):R_"|"_X,X="":R,1:X)
 S Z=""
 F X=1:1:99 S A=$P(R,"|",X) Q:A=""  S:$$CHECK^IMPRP(A,DT) Z=Z_$S(Z="":"",1:CR)_A_"|"_$$NAME^IMPRP(A)
 D MSG^RWU(Z)
 Q
LO(DGN,WRK,DDT,DT,USH,PRGX,PSUM,DF) ; Предварительный список на открепление
 N NI,DH,D,FIO,X,DGT,I,NM,U,CIDX
 S DH=$$DIH^DTUTL($G(DF)),PRGX=$G(PRGX),I=1,(NM,CIDX)=""
 S:PRGX'="" PRGX="|"_PRGX_"|"
 D OWF^RWU(".txt")
 D WC^RWU("№ п.п.|Отметка|№ И.Б.|Участок|Фамилия Имя Отчество|Срок договора|Договор|Программы")
 S DT=$$DIH^DTUTL(DT)
 S:WRK=-1 WRK="" S:WRK=999 WRK=""
 I DGN="" S NI="" F  S NI=$$NEXT^IPAC(NI) Q:NI=""  D LOPRG
 I $L(DGN) S NI="",NM=$$NAMEH^YNDOG(DGN,DH) F  S NI=$$NEXT^IPAC(NI,"stc",DGN) Q:NI=""  D
 .S CIDX=$$PIDXN^IPAC(NI,DGN,DH)
 .Q:CIDX=-1
 .D LOPRG
 D C^RWU
 Q
LOPRG 
 S DGT=$$GET^IPAC(NI,"dog_to"_CIDX,DH)
 I DDT=1 Q:DGT>(DT-1) 
 I DDT=2 Q:DGT>DT 
 I DDT=3 S X=$$GET^IPAC(NI,"dog_from"_CIDX,DH) Q:X<DT 
 I DDT=4 S X=$$GET^IPAC(NI,"dofor",DH) Q:X'=DT 
 I WRK'="",$$GET^IPAC(NI,"work",DH)'=WRK Q 
 I PRGX'="","|"_$$GET^IPAC(NI,"prog"_CIDX,DH)_"|"'[PRGX Q 
 I PSUM'="",$$GET^IPAC(NI,"psumm",DH)'=PSUM Q 
 S U=$$GET^IPAC(NI,"ush",DH) I USH'="",USH'=U Q 
 S FIO=$$GET^IPAC(NI,"fiof",DH)
 S X=NM
 I DGN="" S X=$$GETE^IPAC(NI,"stc",DH)
 D WC^RWU(CR_I_"||"_NI_"|"_U_"|"_$$FIO^IPAC(NI,DH)_"|"_$$DT^DTUTL(DGT)_"|"_X_"|"_$TR($$GETE^IPAC(NI,"prog"_CIDX,DH),"|",","))
 S I=I+1
 Q
SOCFG(SD,MOD,DGN) ; SO config
 S ^JOB(%JOB,"pspis","so-config")=SD_"|"_MOD_"|"_DGN
 Q
SO ; Открепить по списку
 D ORH^RWU
 N %J,U,X,NI,FIO,DH,I,DGT,A,OPF,MOD,A,DGN,PIDX,DSTC,CD
 K ^BUF($J,"btn")
 S X=$G(^JOB(%JOB,"pspis","so-config")) K ^JOB(%JOB,"pspis","so-config")
 S DSTC=$G(^cfg("def-stc")) S:DSTC="" DSTC=$O(^DGN(""))
 S DH=$$DIH^DTUTL($P(X,"|",1)),MOD=+$P(X,"|",2),DGN=$P(X,"|",3),I=1
 F %J=1:1 S A=$$R^RWU Q:%IFN["Z"  D
 .Q:%J=1  S NI=$P(A,"|",3) Q:NI=""  Q:$P(A,"|",2)'="(+)"
 .S ^BUF($J,"btn",NI)=""
 D CR^RWU
 S OPF=$$USR^IUSER()_"|"_$H,PIDX=""
 D OWF^RWU(".txt")
 D WC^RWU("№ п.п.||N И.Б.|Участок|Фамилия Имя Отчество|Срок договора|Договор")
 S NI="" F  S NI=$O(^BUF($J,"btn",NI)) Q:NI=""  D
 .S CD=$$FIRSTDT^IPAC(NI)
 .S DT=$S(DH>CD:DH,1:CD)
 .S:DGN'="" PIDX=$$PIDX^IPAC(NI,DGN,DT)
 .S DGT=$$GET^IPAC(NI,"dog_to"_PIDX,DT)
 .S U=$$GET^IPAC(NI,"ush",DT) 
 .S FIO=$$GET^IPAC(NI,"fiof",DT)
 .D:'MOD
 ..D SET^IPAC(NI,"ofor",DT,2)
 ..D SET^IPAC(NI,"dofor",DT,DT,1)
 .D:MOD=1
 ..D SET^IPAC(NI,"dog_to"_PIDX,DT,DT,1)
 .D:MOD=2
 ..S A=$$NIBDEL(NI) Q:A 
 ..D SET^IPAC(NI,"dog_to"_PIDX,DT,DT,1)
 .D:MOD=3
 ..D SET^IPAC(NI,"ofor",DT,1)
 ..D SET^IPAC(NI,"dofor",DT,DT,1)
 .D:MOD=4 
 ..D SET^IPAC(NI,"ofor",DT,1)
 ..D SET^IPAC(NI,"dofor",DT,DT,1)
 ..D SET^IPAC(NI,"stc"_PIDX,DT,DSTC)
 ..D SET^IPAC(NI,"dog_from"_PIDX,DT,"")
 ..D SET^IPAC(NI,"dog_to"_PIDX,DT,"")
 ..D SET^IPAC(NI,"prog"_PIDX,DT,"")
 ..D SET^IPAC(NI,"polis"_PIDX,DT,"",1)
 .D WLOG^IPAC(NI,DT,$H)
 .S X=$$GETE^IPAC(NI,"stc"_PIDX,DT)
 .D WC^RWU(CR_I_"|(+)|"_NI_"|"_U_"|"_$$FIO^IPAC(NI,DT)_"|"_$$DT^DTUTL(DGT)_"|"_X_"|")
 .S I=I+1
 K ^BUF($J,"btn")
 D C^RWU
 Q
NIBDEL(NIB) ; Delete patient
 N PAR,R,DT,%L,%B,NI
 S NI=NIB
 D NDEL+5^YIPACN
 Q '$D(^BTN(NIB)) 
LPAT ; Load pattern list
 D OWF^RWU(".txt"),W^RWU("|")
 D LPATsys
 D C^RWU
 Q
LPATsys 
 N I,X S I=+$G(^MN("spispat"))
 S X="" F  S X=$O(^MN(I,X)) Q:X=""  D WC^RWU(CR_X_"~"_^(X))
 Q
APAT(NM,R) ; Add pattern
 N I,X S I=$$NEWIDX^YISPRAV("spispat")
 S X=$O(^MN(I,""),-1)+1,^MN(I,X)=$$WD^TXTU(R_"|"_NM)
 D UPD^IEXCH("YISPRAV","spispat")
 G LPAT
DPAT(ID) ; Delete pattern
 G:ID="" LPAT
 N I S I=$$NEWIDX^YISPRAV("spispat")
 K ^MN(I,ID) D UPD^IEXCH("YISPRAV","spispat")
 G LPAT
SPAT(ID,R) ; Save pattern
 N I S I=$$NEWIDX^YISPRAV("spispat")
 S $P(^MN(I,ID),"|",1)=$$WD^TXTU(R)
 D UPD^IEXCH("YISPRAV","spispat")
 G LPAT
LOTAB(ND) ; Load patient list, from backup
 D OWF^RWU(".txt")
 D ODOC
 D C^RWU
 Q
LBK(DT,DF) ; Load backup list
 N X,C,LST,L,R
 S (C,X)="",DT=$$DI^DTUTL($G(DT))
 S DF=$G(DF),DF=$S(+DF=DF:$H-DF+1,1:$$DI^DTUTL(DF))
 S:DT'="" X=DT_","
 K ^BUF($J,"bkl")
 F  S X=$O(^BTNBK(X),-1) Q:X=""  Q:DT'=""&(+X'=DT)  Q:DF'=""&(+X<DF)  D
 .S L=$P(X,",",2),L=$E("000000",1,6-$L(L))_L
 .S R=$$DTM^DTUTL($G(^(X)))_"|"_X
 .S:$D(^BTNBKS(X)) R=R_"@1"
 .S ^BUF($J,"bkl",$P(X,",",1)_","_L)=R
 D OWF^RWU(".txt")
 S X="" F  S X=$O(^BUF($J,"bkl",X),-1) Q:X=""  D WC^RWU(C_^BUF($J,"bkl",X)) S C=CR
 D C^RWU
 K ^BUF($J,"bkl")
 Q
DOBACK(ND) ; Restore backup
 N NI,FYDOCS,FF,R,P
 S FF=1,NI=""
 F  S NI=$O(^BTNBK(ND,NI)) Q:NI=""  D
 .I $O(^BTNBK(ND,NI,""))="" D  Q  ; нет никаких полей
 ..S R=$D(^BILL(NI))
 ..I R,$G(^BILL(NI))=0,$O(^BILL(NI,""))="" S R=0 K ^BILL(NI) D KGL^IEXCH("^BILL",NI)
 ..I '$$CHKNUL^IPAC(NI) S FF=0 Q 
 ..D RMIDX^YIPACN,K^ISSG("^BTN("_NI_")") K ^BTN(NI)
 ..D KGL^IEXCH("^BTN",NI)
 ..K ^BTNBK(ND,NI)
 .D RMIDXU^YIPACN,K^ISSG("^BTN("_NI_")") K ^BTN(NI)
 .S P="" F  S P=$O(^BTNBK(ND,NI,P)) Q:P=""  M ^BTN(NI,P)=^BTNBK(ND,NI,P) ; копирование  только полей, без служебн. инф. в ^BTNBK
 .D MKIDX^YIPACN(+$H)
 .D UPD^IEXCH("IPACEX",NI)
 .K ^BTNBK(ND,NI)
 I FF,$D(^BTNBK(ND))=1 D DEL^YDOCS(ND) K ^BTNBK(ND),^BTNBKS(ND) Q 
 D LOTAB(ND)
 Q
CHKBK ; очистка последних N дней сохраненных списков
 N X,K
 S X=+$G(^cfg("pspis-bk")) Q:X<2 
 S X=($H-X-1)_",0"
 F  S X=$O(^BTNBK(X),-1) Q:X=""  K ^BTNBK(X),^BTNBKS(X)
 Q
BKTEXT(ND) ; Получить исходный список
 N I,R,C
 D OWF^RWU(".txt")
 S (I,C)=""
 F  S I=$O(^BTNBKS(ND,I)) Q:I=""  S R=^(I) D WC^RWU(C_R) S C=CR
 D C^RWU
 Q
TPROF 
 N ID,I,C S I=+$G(^MN("ppspis"))
 D OWF^RWU(".xmlb"),W^RWU(^PP(0,2)_"<skspisin>")
 S C="<prof>Новый профиль|"_CR,ID=""
 F  S ID=$O(^MN(I,ID)) Q:ID=""  D WC^RWU(C_$G(^(ID,"nm"))_"|"_ID) S C=CR
 D:C'=CR WC^RWU(C)
 D W^RWU("</prof><pat>"),LPATsys
 D W^RWU("</pat><alg>"),PLSTsys^NPSPISU
 D W^RWU("</alg></skspisin></nb_console>"),C^RWU
 Q
LPROF(ID) 
 N I S I=$$NEWIDX^YISPRAV("ppspis")
 D OWF^RWU(".xmlb"),W^RWU(^PP(0,2)_"<skspisin>")
 D L^XMLU("^MN("_I_")",ID,"LPROC^NPSPIS")
 D W^RWU("</skspisin></nb_console>"),C^RWU
 Q
LPROC(PL,R)        ; Процедура вывода полей
 I PL="fval" D WTAGC^RWU(PL,R) Q 1 ; как данные
 Q:PL'="progs" 0
 D PRBYDGN(+$G(^MN(I,ID,"stc")))
 D W^RWU("<progs>"_%L_"</progs>")
 D WC^RWU("<progs state="""_R_"""/>")
 K %L,%B
 Q 1
DPROF(ID) 
 N I S I=$$NEWIDX^YISPRAV("ppspis")
 D K^ISSG("^MN("_I_","_ID_")")
 K ^MN(I,ID)
 D UPD^IEXCH("YISPRAV","ppspis")
 D TPROF
 Q
SPROF 
 N ID,I,C
 S I=$$NEWIDX^YISPRAV("ppspis")
 S ID=$$OS^XMLU("^MN("_I_")","skspisin","id")
 D UPD^IEXCH("YISPRAV","ppspis")
 D OWF^RWU(".xmlb"),W^RWU(^PP(0,2)_"<skspisin>")
 D WTAGD^RWU("id",ID),WC^RWU("<prof>Новый профиль|")
 S (C,ID)="" F  S ID=$O(^MN(I,ID)) Q:ID=""  D WC^RWU(C_$G(^(ID,"nm"))_"|"_ID) S C=CR
 D W^RWU("</prof></skspisin></nb_console>"),C^RWU
 Q
REGLCL ; 
 K ^LCLI("pspis")
 S ^LCLI("pspis")="Импорт контингента"
 S ^LCLI("pspis","bill")="Изменение суммы счета"
 S ^LCLI("pspis","lpu")="Привязка к филиалу"
 S ^LCLI("pspis","alg")="Алгоритм по умолчанию"
 S ^LCLI("pspis","def-fld")="Поля по умолчанию: поле=значение;..;.. "
 S ^LCLI("pspis","def-pfld")="Поля по умолчанию для карты профмедицины. Формат поле=значение"
 Q
INITDB 
 S ^MN("root","spispat")="Шаблоны колонок списков (импорт контингента)"
 S ^MN("root","ppspis")="Профили списков (импорт контингента)"
 S ^MN("frm","skspis")="Импорт контингента" 
 Q
