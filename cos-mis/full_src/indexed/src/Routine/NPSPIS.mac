 .S A=A_"ВРЕДНЫЕ ФАКТОРЫ п.29"_CR
 .S A=A_"НАЦИОНАЛЬНОСТЬ"_CR
 .S A=A_"МЕСТО РОЖД."_CR
 .S A=A_"ВНЖ"_CR
 .S A=A_"ПЕРИОД РЕГИСТРАЦИИ"_CR
 .S A=A_"АДРЕС РАБОТЫ"_CR
 .S A=A_"ЛМК"_CR
 .S A=A_"ТИП ЛМК"_CR
 S A=A_"СКИДКА"_CR
 S:$G(^cfg("pspis","prinum")) A=A_"N ПРИКРЕПЛЕНИЯ"_CR
 S:$$LCL^IUSER("pspis","bill") A=A_"СЧЕТ"_CR_"БАЛАНС"_CR
 S:$$LCL^IUSER("pspis","lpu") A=A_"ФИЛИАЛ"_CR
 S A=A_"СТОИМОСТЬ ПОЛИСА"_CR
 S A=A_"ЛИМИТ СУММЫ"_CR
 S A=A_"ФРАНШИЗА в %"_CR
 S A=A_"СУММА ФРАНШИЗЫ"_CR
 S A=A_"СУММА ПОСЕЩЕНИЯ ФР."_CR
 S A=A_"РЕКЛАМА"_CR
 S A=A_"ГДЕ КАРТА"_CR
 S A=A_"АЛЬТ.НОМЕР"_CR
 S A=A_"ДАТА ИЗМЕНЕНИЯ"_CR
 S A=A_"ЕСТЬ УСЛУГИ"_CR
 S A=A_"ДЕЙСТВИЕ"_CR
 Q A
