 S A=A_"СТРАХОВОЙ ДОГ."_CR
 S A=A_"СТРАХ.ПРОГРАММА"_CR
 S A=A_"РАБОТА"_CR
 S A=A_"СНИЛС"_CR
 S A=A_"ПРИМЕЧАНИЕ"_CR
 S:$G(^cfg("profv")) A=A_"ПРОФЕССИЯ"_CR
 S A=A_"ДОЛЖНОСТЬ"_CR
 S A=A_"ПАСПОРТ N"_CR
 S A=A_"ПАСПОРТ ВЫДАН"_CR
 S:$G(^cfg("alt-fio")) A=A_"Ф.ЛАТ."_CR
 S:$G(^cfg("alt-fio")) A=A_"И.ЛАТ."_CR
 S:$G(^cfg("alt-fio")) A=A_"О.ЛАТ."_CR
