New(Id)                                ; новое значение из базы
 N urn,mg,nam
 S nam="SET"
 S:Id="FAM" nam="SETF"
 S urn=$O(^K(Id,nam,ind,""))
 S mg=$O(^K(Id,nam,ind,urn,""))
 Q $G(^D(urn,"NEW",mg))
Sg(Sym)                                ; * Согласная буква *
 Q "БВГДЖЗКЛМНПРСТУФХЦЧШЩ"[Sym
L(Str,N)                               ; * Len-N символов слева *
 Q $E(Str,1,$L(Str)-N)
R(Str,N)                               ; * N символов справа *
 Q:N>$L(Str) Str
 Q $E(Str,$L(Str)-N+1,$L(Str))
