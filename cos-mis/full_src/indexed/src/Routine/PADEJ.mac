FAT(Str)                               ; склонение отчества
 N ind
 Q:Str=""
 S ind=Str_$C(31)_Typ
 I $D(^ISLIB("FAT","SET",ind)) S $P(str,Dlm,3)=^(ind) Q  ;$$New("FAT") Q
 I Typ="R" D FATR Q
 I Typ="D" D FATD Q
 I Typ="W" D FATW Q
 I Typ="T" D FATT Q
 I Typ="P" D FATP Q
 Q
