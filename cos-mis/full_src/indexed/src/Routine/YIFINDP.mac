 W N,!,$P(L51,$C(9),2),!,$P(L51,$C(9),3),!,$P(L51,$C(9),4),!,$G(^M(52,$E(L51,7))),!,DOG_" "_$E($G(^DOG(DOG,TG,3)),1,20),!,$E(L51,50,55),!,$P(L51,$C(9),5),!
