 I $D(^B(IK3)) S AAA=^(IK3),F=$P(AAA,"|",2),F=$TR(F,R,R1),PYN=F I F'[FF S PYN=0 Q
 Q
PYN S PYN=0
 I PPS D  Q
 .I $D(^BT(IK3,"K")) S F=^("K"),F=$P(F,$C(9),2,4),F=$TR(F,$C(9)," "),F=$TR(F,R,R1),PYN=F I F'[FF S PYN=0 Q
 I $D(^BT(IK3)) S F=$G(^BT(IK3,2))_" "_$G(^BT(IK3,3))_" "_$G(^BT(IK3,4)),F=$TR(F,R,R1),PYN=F I F'[FF S PYN=0 Q
