 E  S L51=$G(^BT(N,"K")),OTK=$E(L51,7),DOG=+$E(L51,40,43),L52=$P(L51,$C(9),2)_R_$P(L51,$C(9),3)_R_$P(L51,$C(9),4)_R_$E($G(^M(52,OTK)),1,9)_R_DOG_" "_$E($G(^DOG(DOG,TG,3)),1,20)_R_$E(L51,50,55)_R_$P(L51,$C(9),5)
 S L53="<tr><td class=s1>" S:OTK'=1 L53=L53_"<img src=""/../images/ot.gif"">" S L52=L53_"<a href=""YWH_YIPIKCHL?PR1=%22"_N_"%22""> "_N_"</a></td><td class=s3>"_L52_"</td></tr>"
