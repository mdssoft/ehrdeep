CE S K=1,SE=0,IK3=N K S
 S J1=-1 F J0=1:1 S J1=$N(^BCE(IK3,J1)) Q:J1=-1  D
 .S DT=STG-1 F J2=1:1 S DT=$N(^BCE(IK3,J1,DT)) Q:DT=-1  Q:DT>DTK  D
 ..S NN=-1 F J3=1:1 S NN=$N(^BCE(IK3,J1,DT,NN)) Q:NN=-1  D
 ...S TN=-1 F J4=1:1 S TN=$N(^BCE(IK3,J1,DT,NN,TN)) Q:TN=-1  S DL=-1 F J5=1:1 S DL=$N(^BCE(IK3,J1,DT,NN,TN,DL)) Q:DL=-1  D WCE
 S CC=0,DIA=-1,DIA1="" F  S DIA=$N(S(DIA)) Q:DIA=-1  S:S(DIA)>CC CC=S(DIA),DIA1=DIA
 I DIA1'="" S A=DIA1 D S18 S DIA1=A
 Q
WCE S KL=^(DL),DIA=$P(KL,"/",3)
 ;S AAA=DT D ^MKDT S TGG=$E(BBB,5,6)
 S @("CC=$N(^CE"_TG_"(J1,NN,DT))")
 I CC=-1 S CC=$N(^CE(J1,NN,DT))
 I ND=1!(ND=76)!(ND=16)!(ND=28)!(ND=48)!(ND=47)!(ND=54)!(ND=99) D ^XWUD G SCECU
 I CC=-1 S CC=0
 E  S CC=^(CC)
SCECU S CC=CC*KL,SE=SE+CC
 S:DIA'="" S(DIA)=$G(S(DIA))+CC
 Q
A18 S A=$E("0000",1,5-$L(A))_A
 S L7=+$E(A,1,3),L8=+$E(A,4,5),L9=$D(^D9(L7,"z",L8)),L6=$D(^D9(L7,"r"))
 S:L6=0&(L9=0) A="写谐:"_A_" 薪械褌!" S:L9'=0 A=$P(^D9(L7,"z",L8),"/",2) S:L9=0&(L6'=0) A=$P(^D9(L7,"r"),"/",2)
 Q
S18 ;
 S A=$TR(A,".""","")
 S:$E(A,1)="0" A=$E(A,2,250)
 S:$E(A,1)="0" A=$E(A,2,250)
 I $E(A,1)?1N G A18
 I A="" Q
 S L7=$E(A,1,3),L8=$E(A,4) S:L8="" L8="Z" S L9=$D(^D(L7,"z",L8)),L6=$D(^D(L7,"r")) S:L6=0&(L9=0) A="写谐:"_A_" 薪械褌 !" S:L9'=0 A=$P(^D(L7,"z",L8),"/",2) S:L9=0&(L6'=0) A=$P(^D(L7,"r"),"/",2)
