 S LLU="–Р–С–Т–У–Ф–Х–Ц–Ч–Ш–Щ–Ъ–Ы–Ь–Э–Ю–Я–†–°–Ґ–£–§–•–¶–І–®–©–™–Ђ–ђ–≠–Ѓ–ѓ–Б",LLL="–∞–±–≤–≥–і–µ–ґ–Ј–Є–є–Ї–ї–Љ–љ–Њ–њ—А—Б—В—Г—Д—Е—Ж—З—И—Й—К—Л—М—Н—О—П—С",STR=$TR(STR,LLU,LLL)
 S NIB=-1 F   S NIB=$N(^BTN(NIB)) Q:NIB=-1  S FIO=$G(^BTN(NIB,"fiof")),FIO=$TR(FIO,LLU,LLL) D:FIO[STR YFPC
 K LLU,LLL
