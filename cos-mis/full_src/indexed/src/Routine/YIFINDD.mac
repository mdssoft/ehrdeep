 S OF=$E($P(OF," ",1),1,6)
 S DF=$L(OF),EF=$E(OF,1,DF-1)_$C($A($E(OF,DF))+1#256)
S3 K ^SL S RR=0,SIK3=0,PIK3=-1 F IK1=1:1 Q:OF<0!(OF="")!(EF']OF)  D B:$D(^S(SP,OF)) S OF=$N(^S(SP,OF))
 K OF,SS,SL Q
 ;
B S IK3=-1 F IK2=1:1 S IK3=$N(^S(SP,OF,IK3)) Q:IK3<0  D PYN I PYN'=0 S ^SL(IK3)="",SIK3=SIK3+1,PIK3=IK3
 Q
PYN S PYN=0
 I $D(^BT(IK3,"K")) S F=^("K"),F=$P(F,$C(9),2,4),F=$TR(F,$C(9)," "),F=$TR(F,R,R1),PYN=F I F'[FF S PYN=0 Q
 Q
SSP ;
 S (FF,OF)=OF
 S OS="=" I OF["*" S (FF,OF)=$P(OF,"*",1),OS="[" S EF=$E(OF_"zzzzzz",1,16),OF=$E(OF_"      ",1,16)
 E  S DF=$L(OF),EF=$E(OF,1,DF-1)_$C($A($E(OF,DF))+1#256)
 K ^SL S RR=0,SIK3=0,PIK3=-1 F IK1=1:1 Q:OF<0!(OF="")!(EF']OF)  D BP:$D(^S(SP,OF)) S OF=$N(^S(SP,OF))
 K OF,SS,SL Q
 ;
