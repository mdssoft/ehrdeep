 S L7=$E(A,1,3),L8=$E(A,4) S:L8="" L8="Z" S L9=$D(^D(L7,"z",L8)),L6=$D(^D(L7,"r")) S:L6=0&(L9=0) A="–і–≥:"_A_" –љ–µ—В !" S:L9'=0 A=$P(^D(L7,"z",L8),"/",2) S:L9=0&(L6'=0) A=$P(^D(L7,"r"),"/",2)
