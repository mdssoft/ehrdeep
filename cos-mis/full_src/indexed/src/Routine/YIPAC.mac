L(N) ;
 S EN("street")="",EN("stroen")="",EN("tel1")="",EN("tel2")="",EN("text")="",EN("korp")="",EN("kvart")="",EN("domkod")="",EN("dom")="",EN("email")="",EN("pager")=""
 S N=+N
 I '$D(^BTN(+N)) S N="",FIO="",FN="1.XMLB" D OW^YITEL S A=$G(^PP(0,1)) ZZW A ZZW "<patients><hist>" S A=N_"</hist><fio>"_FIO_"</fio>" ZZW A S R=N,POLE="hist_old" D POLE G CCC
 S TG=^TG,RZ=$C(9)
 S FN="1.XMLB" D OW^YITEL
 S A=$G(^PP(0,1)) ZZW A
 ZZW "<patients><hist>" S A=N_"</hist>" ZZW A
 S R=N,POLE="hist_old" D POLE
 ;S C2=+N
 ;I $G(^PP)["LDC" D RAZF^XWKONE
 ;I %LOG'=102&(%LOG'=(+C(16))) S N="",FIO="",FN="1.XMLB" D OW^YITEL S A=$G(^PP(0,1)) ZZW A ZZW "<patients><hist>" S A=N_"</hist><fio>"_FIO_"</fio>" ZZW A S R=N,POLE="hist_old" D POLE D  G CCC
 ;.F J=2:1:30 S C(J)=""
 S POLE=-1 F  S POLE=$N(^BTN(N,POLE)) Q:POLE=-1  D
 .S ENB="" S:%LOG'=102&('$D(EN(POLE))) ENB=" enabled=""no"" "
 .S R=$G(^BTN(N,POLE)),R=$TR(R,"""","'") S A="<"_POLE_ENB_" data="""_R_"""/>" S:POLE="status" A="<"_POLE_ENB_">"_R_"</"_POLE_">" ZZW A Q
 S POLE="tprog",PR1=$G(^BTN(N,"pr1")),A="<"_POLE_">1|"_$G(^M(70,PR1))_"</"_POLE_">" ZZW A
CCC ZZW "</patients>"
 S %B=FN D C^YITEL
 Q
LP(N) ;
 S N=+N,TG=^TG
 S %A=+N X ^PP(1,22) S FIO=%A
 I '$D(^BT(+N)) S N="" D
 .F J=2:1:30 S C(J)=""
 S FN="1.XMLB" D OW^YITEL
 S A=$G(^PP(0,2)) ZZW A
 ZZW "<priem><nib>" S A=N_"</nib><fiov>"_FIO_"</fiov>" ZZW A
 S C2=+N
 I $G(^PP)["LDC" D RAZF^XWKONE
 I $G(^PP)["220" D ^YIPAC220
 S R=C(8),POLE="ofor",R=$S(R=1:" ",R=3:"Умер",1:"Снят") D POLE1
 S R=+C(16),R=R_" "_$G(^DOG(R,2))_$G(^DOG(R,TG,3)),POLE="dog" D POLE1
 S R=C(18),POLE="dogf" D POLED
 S R=C(19),POLE="dogto" D POLED
 S R=C(10),POLE="datar" D POLED2
 ZZW "</priem></nb_console>"
 S %B=FN D C^YITEL
 Q
YY(N) ;
 ;I N'?1N.N S N=""
 S:%W N=$TR(N,%WD,%DW) S STR=N
 S PPS=$G(^PP)["LDC"
 S FN="1.XMLB" D OW^YITEL
 S A=$G(^PP(0,2)) ZZW A
 ZZW "<priem><table2>"
 D POI^YIFIND
 ;S A="ПАЦИЕНТ|ДОГОВОР|СРОК" ZZW A,!
 ;S %A=N X ^PP(1,26) S NI=N_" "_%A ZZW NI,!
 S A="</table2></priem></nb_console>" ZZW A
 S %B=FN D C^YITEL
 Q
CHIFR ;ЗАГУЗКА ШИФРАТОРОВ
 D ^YCHIFR Q
 Q
NNIB(N) ;НОВЫЙ НОМЕР
 S %B="1.NB-DATA"
 Q
ZP ;ЗАМЕНА ПРОГРАММ
 S NI=0 F  S NI=$N(^BT(NI)) Q:NI=-1  D
 .S L=$G(^BT(NI,"K")) Q:L=""
 .S L=$E(L,1,55)_$TR($E(L,56,62),"123456789ПС0","ЭЯСАБВ123450")_$E(L,63,999),^BT(NI,"K")=L
 Q
