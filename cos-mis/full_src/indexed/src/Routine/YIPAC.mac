 S POLE="pin" S R=$G(^BTNEW(N,POLE)),R=R_" "_$P($G(^P(R,"V")),"/",2) I R'="" S A="<"_POLE_" data="""_R_"""/>" ZZW A
 Q
POLE S A="<"_POLE_">"_R_"</"_POLE_">" ZZW A Q
POLE1 S A="<"_POLE_" data="""_R_"""/>" ZZW A Q
POLED S:R="000000"!(R="") R="101010" S:$E(R,1,2)="00"!($E(R,3,4)="00") R="0107"_$E(R,5,6) S R=$S($E(R,5,6)>50:$E(R,1,4)_"19"_$E(R,5,6),1:$E(R,1,4)_"20"_$E(R,5,6)) S A="<"_POLE_">"_$E(R,1,2)_"."_$E(R,3,4)_"."_$E(R,5,8)_"</"_POLE_">" ZZW A Q
POLED2 S:R="000000"!(R="") R="101010" S:$E(R,1,2)="00"!($E(R,3,4)="00") R="0107"_$E(R,5,6) S R=$S($E(R,5,6)>5:$E(R,1,4)_"19"_$E(R,5,6),1:$E(R,1,4)_"20"_$E(R,5,6)) S A="<"_POLE_">"_$E(R,1,2)_"."_$E(R,3,4)_"."_$E(R,5,8)_"</"_POLE_">" ZZW A Q
POLEW S R=$G(^BTNEW(N,POLE)) D  I R'="" S A="<"_POLE_" data="""_R_"""/>" ZZW A Q
 .Q:R'[""""
 .S R1="" F JR=1:1:$L(R) S RR=$E(R,JR) S:RR="""" RR="'" S R1=R1_RR ;RR="%22" S R1=R1_RR
 .S R=R1
 Q
LIST(NAM) ;списоки отделений, программ и пр.
 S FN="1.XML" D OW^YITEL
 I NAM="mectorab" S N=5 D MML
