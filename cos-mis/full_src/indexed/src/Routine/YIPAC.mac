MMLA 
 Q
MMLB X "F ND="_SN_" D:$D(^M(N,ND)) MMLBB"
 Q
FIO(NI) ; Полная фамилия
 Q:$D(^BTN(NI))=0 ""
 Q $G(^BTN(NI,"fiof"))_" "_$G(^("fioi"))_" "_$G(^("fioo"))
FIOIO(NI) ; Имя Отчество
 Q:$D(^BTN(NI))=0 ""
 Q $G(^BTN(NI,"fioi"))_" "_$G(^("fioo"))
FIOSH(NI) ; Сокращенная фамилия
 Q:$D(^BTN(NI))=0 ""
 S A=$G(^BTN(NI,"fiof")) I $G(^("fioi"))'="" S A=A_" "_$E($G(^("fioi")),1,1)_"." S:$G(^("fioo"))'="" A=A_" "_$E($G(^("fioo")),1,1)_"."
 Q A
 
 
