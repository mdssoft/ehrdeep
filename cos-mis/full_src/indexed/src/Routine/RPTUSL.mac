 I PL="stzn" S:'$D(stzn) stzn=$$GETPL^IUSL(VR,DT,OT,ID,"zi") Q stzn
 I PL="nul" Q ""
 I PL="nn" Q ""
 Q ""
IsAclEq(Xs,Xpt) ; совпадение аналитического кода с шаблоном
 N I,X,Q
 S Q=1
 F I=1:1:$L(Xpt,".") S X=$P(Xpt,".",I) I X'="",X'="*",X'=$P(Xs,".",I) S Q=0 Q
 Q Q
setCol(I,V) ; Установить значение столбца
 S ^BUF($J,0,BIDX,I)=$TR(V,"|",";")
 Q
getCol(I) ; Получить значение столбца
 Q $G(^BUF($J,0,BIDX,I))
getKey() ; Получить значение ключа
 Q $G(^BUF($J,0,BIDX,"k"))
getSTC() 
 Q:$D(CSTC) CSTC
 S CSTC=$S($D(ISTC):ISTC,1:$$GETTZ^IPAC(NI,TZstc,DT))
 Q CSTC
getPRC() 
 Q:$G(PRC) PRC
 S CSTC=$S($D(CSTC):CSTC,$D(ISTC):ISTC,1:$$GETTZ^IPAC(NI,TZstc,DT))
 S PRC=+$$GET^IINSC(CSTC,"price",DT) S:'PRC PRC=DEFPRC
 Q PRC
cvSMATT()       ; Сумма материалов
 N X S X=$$GET^IPRICE(U,"mat",$$getPRC(),DT) Q:X="" 0
 Q $$CENNALL^IWRHS(X,DT)
cvPMATT()       ; Продажа материалов
 N X S X=$$GETPL^IUSL(VR,DT,OT,ID,"mt") Q:X="" 0
 Q $$CENNALL^IWRHS(X,DT)
cvNMATT()       ; Продажа материалов
 N X S X=$$GETPL^IUSL(VR,DT,OT,ID,"mt") Q:X="" 0
 Q $$NAMESALL^IWRHS(X)
cvWSMATT() ; Сумма на складе у материалов
 N X
 S X=$$GETPLE^IUSL(VR,DT,OT,ID,"mt") Q:X="" 0
 Q $$KEYSUMM^IWRH(X)
DOout 
 N ENDLN,SUBLN,SI,SP,SR,KEY,X,X1,X2,BASE,VV,LE,CE,J,nn
 ; заголовок
 S R="",I=0 F  S I=$O(TABLN(I)) Q:I=""  S $P(R,"|",I)=TABLN(I)
 D W^RWU(tKEYI_"|"_R)
 
 S LE=$O(TABLN(I),-1) ; last
 S nn=1
 S RX="" F  S RX=$O(^BUF($J,0,RX)) Q:RX=""  D
 .S R=$P(RX,"|",2,99),KEY=""
 .S I="" F  S I=$O(^BUF($J,0,RX,I)) Q:I=""  S:I'="k" $P(R,"|",I)=^(I) S:I="k" KEY=^(I)
 .S VV=1
 .S:$P(R,"|",LE)="" $P(R,"|",LE)="" ; full line fix
 .F I=1:1:LE D
 ..I '$D(TABLN(I)) S $P(R,"|",I)="ошибка" Q 
 ..S BASE=$P(R,"|",I)
 ..S K=$S($D(TABLN(I,9)):BASE,1:$$DOoutfn(BASE,TABLN(I,2),$G(TABLN(I,1))))
 ..S K=$S($D(TABLN(I,5)):$$DOcrop(K,TABLN(I,5)),1:K),$P(R,"|",I)=K
 ..S X=$G(TABLN(I,7)) ; result function
 ..I X'="" S K=X,X=$P(R,"|",I) X "S K="_K S $P(R,"|",I)=K
 ..S X=$G(TABLN(I,8))
 ..I X'="" S XE=X,X=K X "S K="_XE I 'K S VV=0
 .Q:'VV 
 .F I=1:1:LE D
 ..S X=+$TR($P(R,"|",I),",",".")
 ..S:$G(TABLN(I,6)) ENDLN(I)=$G(ENDLN(I))+X
 ..S SI=$G(TABLN(I,61))
 ..Q:'SI
 ..S X1=+$TR($P(R,"|",SI),",","."),SP=$G(SUBLN(I,1)),X2=$G(SUBLN(I,2))
 ..I SP'="",SP'=X1 S SR="",$P(SR,"|",SI)="Подитог",$P(SR,"|",I)=X2,X2=0 K SUBLN(I,2) D WC^RWU(CR_"|"_SR) ; вывод подитога по колонке
 ..S:SP'=X1 SUBLN(I,1)=X1 
 ..S SUBLN(I,2)=X2+X
 .D WC^RWU(CR_$$TAG^TXTU(KEY_"|"_R))
 .S nn=nn+1
 
 ; Подитоги (остаток)
 S (R,I)="" F  S I=$O(SUBLN(I)) Q:I=""  S X2=$G(SUBLN(I,2)) I X2'="" S $P(R,"|",$G(TABLN(I,61)))="Подитог",$P(R,"|",I)=X2
 D:R'="" WC^RWU(CR_"|"_R)
 
 ; Итоги
 Q:'$D(ENDLN)
 S (R,I)="" F  S I=$O(ENDLN(I)) Q:I=""  S $P(R,"|",I)=$G(ENDLN(I))
 D WC^RWU(CR_"|"_R)
 Q
gCol(I) ; for result function
 ; detect digits
 Q $S($$isFLdig(TABLN(I,2)):$TR($P(R,"|",I),",","."),1:$P(R,"|",I))
num(X,DIG) 
 Q $TR($J(X,"",DIG),".",",")
DOoutfn(X,FL,AFN) ; Обработчик результата
 ; AFN - ф-ция агрегации
 ; EFN - итоговая ф-ция суммы
 I AFN'="" Q:AFN="UCNT"!(AFN="SUM")!(AFN="CNT")!(AFN="MIN")!(AFN="MAX") $TR(X,".",",")
 I FL="NI" Q $$FIO^IPAC(X)
 I FL="DT" Q $$DT2^DTUTL(X)
 I FL="DIA" Q $$NAME^YMKB10(X)
 I FL="OT" Q $$GOTD^YISPRAV(X)
 I FL="VR" Q $$FIO^IKADRY(X)
 I FL="ms" Q $$FIO^IKADRY(X)
 I FL="SP" Q $$SPEC^ISPRAV(X)
 I FL="SPrt" Q $$GET^ISPRAV("specrtp",X)
 I FL="LPU" Q $$NAME^ICONTR(X)
 I FL="CSTC" Q $$NAME^IINSC(X)
 I FL="PRC" Q $$NAME^ISPRAV("tprice",X)
 I FL="UPRG" Q $$NAME^IMPRP(X) 
 I FL="pgrp" Q $$NAME^ISPRAV("gprice",X)
 I FL="U" Q X_" "_$$NAME^IPRICE(X,$$STARTTP^IPRICE(X,DE,,DEFCPRC))
 I FL="Un" Q $$NAME^IPRICE(X,$$STARTTP^IPRICE(X,DE,,DEFCPRC))
 I FL="Ud" Q $$NAMEH^IPRICE($P(X,"@",1),$P(X,"@",2),$P(X,"@",3))
 I FL="dvid" Q $$NAME^ISPRAV("dvid",X)
 I FL="dgtype" Q $$NAME^ISPRAV("dgtype",X)
 I FL="con" Q $$NAME^ICONTR(X)
 I FL="zak" Q $$NAME^ICONTR(X)
 I FL="NI4phone" Q $S(NoPHN:"",1:$$TELS^IPAC(X))
 I FL="NI4mphone" Q $S(NoPHN:"",1:$$MPHN^TXTU($P($P($$GET^IPAC(X,"pager"),",",1),"/",1)))
 I FL="NI4addr" Q $$ADR^YIPACN(X)
 I FL="NI4datar" Q $$DT^DTUTL(X)
 I FL="NI4wrk" Q:X="" "" Q $G(^M(5,X))
 I FL="NI4ush" Q:X="" "" Q $$GUCH^YISPRAV(X)
 I FL="NI4prg" Q:X="" "" Q $$NAMES^IMPRP($TR(X,";","|"))
 I FL="NI4rsource" Q $$NAME^ISPRAV("rsource",X)
 I FL="NI4pol" Q $$NAME^ISPRAV("gender",X)
 I FL="NI4stcdog" Q X
 I FL="NI4stcprg" Q X
 I FL="NI4psumm" Q X
 I FL="NI4email" Q X
 I FL="NI4crea" Q $$DT^DTUTL(X)
 I FL="NI4vagent" Q $$FIO^IKADRY(X)
 I FL="NI4cagent" Q $$GSTAFF^ICONTR(X)
 I FL="NI4df" Q $$DT^DTUTL(X)
 I FL="NI4dt" Q $$DT^DTUTL(X)
 I FL="ntime" Q $$TM^DTUTL(X)
 I FL="fnaz" Q $$FIO^IKADRY(X)
 I FL="fnazs" Q $$SPEC^ISPRAV(X)
 I FL="cowrk" Q $$FIO^IKADRY(X)
 I FL="USLdtm" Q $$DTM^DTUTL(X)
 I FL="USLsdtm" Q $$DTM^DTUTL(X)
 I FL="upaydt" Q $$DTM^DTUTL(X)
 I FL="nn" Q nn
 I $$isFLdig(FL) Q $TR(X,".",",")
 Q X
isFLdig(FL) ; Поле является числом
 Q:FL="cenn" 1
 Q:FL="cenn1" 1
 Q:FL="summ1" 1
 Q:FL="summ" 1
 Q:FL="summz" 1
 Q:FL="cnt" 1
 Q:FL="mat" 1
 Q:FL="matwrh" 1
 Q:FL="SKD" 1
 Q:FL="cntzub" 1
 Q:FL="rgd" 1
 Q:FL="sbs" 1
 Q:FL="uslkc" 1
 Q:FL="uetv" 1
 Q:FL="uetms" 1
 Q:FL="nazdl" 1
 Q:FL="NI4psumm" 1
 Q:FL="NI4sumlimit" 1
 Q 0
fnFpos() ; Функция, что посещение первое (относительно спец.)
 S:$G(SP)="" SP=$$SPEC^IKADRY(VR,DT)
 Q:$G(^BUF($J,"tmp","fpos",NI,SP))=1 0 ; found before
 N X S X=$G(^(SP))
 I X'="",X<DT Q 0 ; на дату первичных точно нет
 S ^(SP)=DT
 I $$IsFPSP^IUSL(NI,OT,VR,DT,ID) S ^BUF($J,"tmp","fpos",NI,SP)=1 Q 1
 Q 0
getPTP(NI,VR,DT,OT,ID) ; Тип платежа по услуге
 S ID=$$GETPL^IUSL(VR,DT,OT,ID,"p") Q:ID="" 0
 Q +$P($$NEARPAY^IBILL(NI,ID),"|",2)
DOcrop(X,MAX) ; Ограничить в ширину
 I $L(X)<MAX Q X
 Q $E(X,1,MAX-2)_".."
LSTFLT(TP) ; Список для фильтра
 N FL,ID
 S (A,FL)=""
 S ID=$S(TP="oper":TP,TP="func":TP,1:"out")
 S A="=|Значение"
 S:TP="func" A="|"
 F  S FL=$O(^SRPTUSLM(ID,FL)) Q:FL=""  S A=$S(A="":"",1:A_CR)_FL_"|"_^(FL)
 I ID'="out" D MSG^RWU(A) Q 
 F  S FL=$O(^SRPTUSLM("prm",FL)) Q:FL=""  S A=$S(A="":"",1:A_CR)_FL_"|"_^(FL)
 D MSG^RWU(A)
 Q
EXPORT(ID) ; Экспорт отчета
 N DATA,X,GL,FLD,FLDNM
 M DATA=^SRPTUSL(ID)
 S FLD=$G(^SRPTUSL(ID,"fld"))
 S FLDNM=$$NAME^ISPRAV("rptuslfld",FLD)
 S GL(1)="DATA"
 S GL(2)="FLD"
 S GL(3)="FLDNM"
 D S^XGUNET("GL",".bin")
 Q
IMPORT ; Импорт отчета
 N DATA,X,GL,FLD,FLDNM,ID
 D R^XGUNET("hpar",0) ; no reencode
 I '$D(DATA) D MSG^RWU("Ошибка при импорте файла") Q
 L +^SRPTUSL
 S ID=$O(^SRPTUSL(""),-1)+1 M ^SRPTUSL(ID)=DATA
 L -^SRPTUSL
 I $G(FLDNM)'="",$D(FLD) D
 .S FLD=$$FINDN^ISPRAV("rptuslfld",1,FLDNM,1)
 .S:FLD="" FLD=$$ADDFN^ISPRAV("rptuslfld",FLDNM)
 .S ^SRPTUSL(ID,"fld")=FLD
 D REGL^IEXCH("^SRPTUSL",ID)
 Q
