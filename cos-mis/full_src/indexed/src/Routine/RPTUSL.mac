RPTUSL ; Отчет по услугам [ 11/29/2023  1:34 AM ]
INIT ; Инициализация формы и справочников
 N FL,NM,C,P
 D OWF^RWU(".xmlb"),W^RWU($G(^PP(0,2))_"<rptusl><fl>")
 S (FL,C)="" F  S FL=$O(^SRPTUSLM("out",FL)) Q:FL=""  D WC^RWU(C_FL_"|"_^(FL)) S C=CR
 D W^RWU("</fl><dofl>")
 D WC^RWU("NIk:xpatient:patient|Пациент")
 D WC^RWU(CR_"NIk:mhist:env:pac|ЭМК")
 D WC^RWU(CR_"NIk:nzlist:env:pac|Лист назначений")
 D WC^RWU(CR_"NIk:pacrasp:patient|Расписание пациента")
 D WC^RWU(CR_"NIk:tth:env:pac|Краткий эпикриз")
 D WC^RWU(CR_"NIk:pdigest:env:pac|Дайджест пациента")
 D WC^RWU(CR_"NIk:ksopac:env:pac|Платежи пациента")
 D W^RWU("</dofl><ucls>")
 S FL="kss|Касса"_CR_"!kss|Не касса"
 S FL=FL_CR_"grn|Гарант. письмо"_CR_"!grn|Не гарант. письмо"
 S FL=FL_CR_"nop|Неоплачиваемо"_CR_"!nop|Не неоплачиваемо"
 S FL=FL_CR_"acu|Острое сост."_CR_"!acu|Не острое сост."
 S FL=FL_CR_"npg|Игнор. программы"_CR_"!npg|Не игнор. программы"
 S FL=FL_CR_"npd|Игнор. диагноз"_CR_"!npd|Не игнор. диагноз"
 D WC^RWU(FL)
 S FL=""
 F  S FL=$O(^EPRSP("flg",FL)) Q:FL=""  S NM=$G(^(FL,"nf")) I NM'="",FL'="kss",FL'="grn",FL'="nop",FL'="acu",FL'="npg",FL'="npd" D WC^RWU(CR_FL_"|"_NM_CR_"!"_FL_"|Не "_NM)
 D W^RWU("</ucls><pcls>")
 S (FL,C)=""
 F  S FL=$$NEXT^ISPRAV("pricecls",FL) Q:FL=""  S NM=$$NAME^ISPRAV("pricecls",FL) D WC^RWU(C_FL_"|"_NM_CR_"!"_FL_"|Не "_NM) S C=CR
 D W^RWU("</pcls><lpu>")
 D LSTFIsys^YCONTR("")
 D W^RWU("</lpu><roles>")
 D LSTs^NROLES("")
 D W^RWU("</roles><fld>")
 D LSTs^NSPRAV("rptuslfld")
 D W^RWU("</fld>")
 S P=$$PRC^IINSC("","",+$H,1) ; kss
 D WTAGD^RWU("price",P)
 D WTAGD^RWU("cuprice",P)
 D W^RWU("</rptusl></nb_console>")
 D C^RWU
 Q
LST ; Список отчетов
 D LSTF("")
 Q
LSTF(STR) ; Список отчетов с поиском
 N I,C,R,RR,A,F,FC,LL
 S STR=$$UL^TXTU($$TRIM^TXTU($$WD^TXTU(STR)))
 D OWF^RWU(".txt")
 S (I,C)="",RR="|"_$$ROLE^NUSER()_"|"
 F  S I=$O(^SRPTUSL(I)) Q:I=""  D
 .S R=^(I),A=$G(^(I,"roles"))
 .I A'="",("|"_A_"|")'[RR Q  ; нет прав для просмотра
 .S F=+$G(^("fld"))
 .I STR'="",$$UL^TXTU(R)'[STR Q 
 .S LL(F,I)=R
 S F="" F  S F=$O(LL(F)) Q:F=""  D
 .I F D WC^RWU(C_"|"_$$NAME^ISPRAV("rptuslfld",F)) S C=CR
 .S FC=$S(F:$C(9),1:"")
 .S I="" F  S I=$O(LL(F,I)) Q:I=""  D
 ..D WC^RWU(C_FC_I_"|"_LL(F,I))
 ..S C=CR 
 D C^RWU
 Q
L(ID) ; Загрузить параметры отчета
 Q:ID=""  Q:'$D(^SRPTUSL(ID)) 
 N R,FL,I,X,RX,RXX,PRM,K,LST,I
 K ^JOB(%JOB,"rptusl","t") ; clear temp buf.
 S ^JOB(%JOB,"rptusl","id")=ID
 D OWF^RWU(".xmlb"),W^RWU($G(^PP(0,2))_"<rptusl>")
 S R=^SRPTUSL(ID)
 D WTAGDC^RWU("id",ID)
 D WTAGDC^RWU("infolabel",R)
 D WTAGDC^RWU("nm",R)
 F FL="df","dt","otd","spec","lpu","pid","text","roles","prnpt","ro","fld" D WTAGDC^RWU(FL,$G(^SRPTUSL(ID,FL)))
 S R=$G(^SRPTUSL(ID,"vr")),K=""
 F I=1:1 S X=$P(R,"|",I) Q:X=""  S K=$S(K="":"",1:K_CR)_X_"|"_$$FIO^IKADRY(X)
 D WTAGC^RWU("vr",K)
 S K=""
 ; загрузка таблицы колонок и фильтров
 S R="" F  S R=$O(^SRPTUSL(ID,"tab",R)) Q:R=""  S X=^(R),LST(X)=R
 
 S X="" F  S X=$O(LST(X)) Q:X=""  D
 .S R=LST(X),K=$S(K="":"",1:K_CR)_R_"|"_$S(R=0:"Основной фильтр таблицы",1:$G(^SRPTUSL(ID,"tab",R,"flnm")))
 .F FL="flnm","fl","flagr","ucls","pcls","usls","flsym","diag","psumm","psummi","fltexe","dfnexe","dofl","rfnx","rfnln" S ^JOB(%JOB,"rptusl","t",R,FL)=$$DW^TXTU($G(^SRPTUSL(ID,"tab",R,FL)))
 .S (FL,RX)="" F  S FL=$O(^SRPTUSL(ID,"tab",R,"acl",FL)) Q:FL=""  S RX=RX_CR_FL_"|"_^(FL)
 .S ^JOB(%JOB,"rptusl","t",R,"acl")=RX ; аналитические коды
 .S I="",RX="x" F  S I=$O(^SRPTUSL(ID,"tab",R,"flt",I)) Q:I=""  D
 ..S FL=^(I),RX=RX_CR_FL_"|",FX=""
 ..S PRM=$P(FL,"@",1),$P(FX,"|",1)=$S(PRM="":"",$E(PRM)="=":$E(PRM,2,99),$D(^SRPTUSLM("out",PRM)):^(PRM),1:^SRPTUSLM("prm",PRM))
 ..S PRM=$P(FL,"@",2),$P(FX,"|",2)=$S(PRM="":"",1:^SRPTUSLM("oper",PRM))
 ..S PRM=$P(FL,"@",3),$P(FX,"|",3)=$S(PRM="":"",$E(PRM)="=":$E(PRM,2,99),$D(^SRPTUSLM("out",PRM)):^(PRM),1:^SRPTUSLM("prm",PRM))
 ..S PRM=$P(FL,"@",4),$P(FX,"|",4)=$S(PRM="":"",1:^SRPTUSLM("func",PRM))
 ..S RX=RX_FX
 .S ^JOB(%JOB,"rptusl","t",R,"flt")=$$DW^TXTU(RX) ; фильтры
 
 S:'$L(K) K="0|Основной фильтр таблицы"
 D WTAGC^RWU("tab",K)
 
 K LST,K
 D WTAGC^RWU("descr",$G(^SRPTUSL(ID,"descr")))
 D W^RWU("</rptusl></nb_console>")
 D C^RWU
 Q
MK ; Создать новый отчет
 K ^JOB(%JOB,"rptusl")
 Q
DELRPT(ID,NLST) ; Удалить отчет
 ; NLST - без вывода списка
 Q:ID="" 
 S NLST=$G(NLST)
 I $$LCL^IUSER("rptusl","del")=0 D:'NLST LST D:NLST MSG^RWU("Нет прав на удаление") Q
 I $G(^cfg("rptusl","backup")) M ^SRPTUSLB($H,ID)=^SRPTUSL(ID)
 K ^SRPTUSL(ID)
 D KGL^IEXCH("^SRPTUSL",ID)
 D:'NLST LST
 Q
S ; Сохранить параметры отчета
 D RBUFH^YIXMLRR(1)
 D W
 D CLOSE^YIXMLRR
 Q
W ; Запись
 N R,RR,NBC,ID,FL,I,X,K,A,IDX
 S NBC="nb_console",ID=$G(XML(NBC,"rptusl","id"))
 I ID'="",$$LCL^IUSER("rptusl","save")=0 D MSG^RWU("Изменение отчета запрещено - нет прав.") Q 
 I ID'="",$G(^SRPTUSL(ID,"ro")),$G(XML(NBC,"rptusl","ro")) D MSG^RWU("Сохранение отчета запрещено.") Q
 I ID="",$$LCL^IUSER("rptusl","new")=0 D MSG^RWU("Создание отчета запрещено - нет прав.") Q 
 I ID="" L ^SRPTUSL S ID=$O(^SRPTUSL(""),-1)+1,^(ID)="" L -^SRPTUSL
 S R=$G(XML(NBC,"rptusl","nm"))
 S:R="" R="Новый отчет "_ID
 S ^SRPTUSL(ID)=R
 F FL="df","dt","otd","spec","lpu","pid","text","roles","prnpt","ro","fld" S ^SRPTUSL(ID,FL)=$G(XML(NBC,"rptusl",FL))
 S R=$G(XML(NBC,"rptusl","vr")),RR=""
 F I=1:1 S X=$P(R,CR,I) Q:X=""  S $P(RR,"|",I)=X
 S ^SRPTUSL(ID,"vr")=RR
 ; таблица и фильтры
 S R=$G(XML(NBC,"rptusl","tab"))
 K ^SRPTUSL(ID,"tab")
 F I=1:1 S X=$P(R,CR,I) Q:X=""  D
 .S IDX=$P(X,"|",1)
 .S ^SRPTUSL(ID,"tab",IDX)=I-1
 .F FL="flnm","fl","flagr","flsym","ucls","pcls","usls","diag","psumm","psummi","fltexe","dfnexe","price","dofl","rfnx","rfnln" S ^SRPTUSL(ID,"tab",IDX,FL)=$$WD^TXTU($G(^JOB(%JOB,"rptusl","t",IDX,FL)))
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"acl")) ; аналит. коды
 .F K=2:1 S A=$$WD^TXTU($P(X,CR,K)) Q:A=""  S:$P(A,"|",1)'="" ^SRPTUSL(ID,"tab",IDX,"acl",$P(A,"|",1))=$P(A,"|",2)
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"flt")) ; фильтры
 .F K=2:1 S A=$P(X,CR,K) Q:A=""  S A=$P(A,"|",1) S:A'="" ^SRPTUSL(ID,"tab",IDX,"flt",K-1)=$$WD^TXTU(A)
 
 S ^SRPTUSL(ID,"log",$H)=$$USRH^IUSER()
 
 D MSG^RWU(^PP(0,2)_"<rptusl><id data="""_ID_"""/></rptusl></nb_console>",".xmlb")
 D REGL^IEXCH("^SRPTUSL",ID)
 Q
STAB ; Save temporary table field
 N ID,NB,FL
 D RBUFH^YIXMLRR(0)
 S NB="nb_console",ID=$G(XML(NB,"rptusl","tabid"))
 S:ID="" ID=$O(^JOB(%JOB,"rptusl","t",""),-1)+1,^(ID,"flnm")=""
 K ^JOB(%JOB,"rptusl","t",ID)
 K XML(NB,"rptusl","tabid")
 M ^JOB(%JOB,"rptusl","t",ID)=XML(NB,"rptusl")
 S ^JOB(%JOB,"rptusl","id")=$G(XML(NB,"rptusl","id"))
 Q
LTAB(ID) ; Load temporary table field
 N FL,R,PRC,X,I,C
 D OWF^RWU(".xmlb")
 D W^RWU(^PP(0,2)_"<rptusl>")
 F FL="flnm","fl","flagr","flsym","psumm","psummi","fltexe","dfnexe","price","dofl","rfnx","rfnln" D WTAGD^RWU(FL,$G(^JOB(%JOB,"rptusl","t",ID,FL)))
 F FL="ucls","pcls","acl","flt" D WTAG^RWU(FL,$G(^JOB(%JOB,"rptusl","t",ID,FL)))
 S PRC=$$CORCP^IPRICET(1),R=$G(^JOB(%JOB,"rptusl","t",ID,"usls")),C=""
 D W^RWU("<usls>")
 F I=1:1 S X=$P(R,CR,I) Q:X=""  D WC^RWU(C_$$TAG^TXTU(X_"|"_X_" "_$$NAME^IPRICE(X,PRC))) S C=CR
 D W^RWU("</usls><diag>")
 S R=$G(^JOB(%JOB,"rptusl","t",ID,"diag")),C=""
 F I=1:1 S X=$P(R,CR,I) Q:X=""  D WC^RWU(C_X_"|"_$$NAME^YMKB10(X)) S C=CR
 D W^RWU("</diag></rptusl></nb_console>")
 D C^RWU
 Q
DTAB(ID) ; Delete temporary table field
 Q:ID="" 
 K ^JOB(%JOB,"rptusl","t",ID)
 Q
NTAB(NM) ; New number
 S %L=$O(^JOB(%JOB,"rptusl","t",""),-1)+1,^(%L,"flnm")=NM,%B=".txt"
 Q
DO ; Выполнить отчет
 N NBC,DS,DE,OTL,VRL,SPL,LPUL,DT,OT,VR,ID,IDX,I,R,X,K,FLT,TABLN,QQ,VARPL
 N FI,FX,FR,FK,U,FLGl,PCLS,ACLS,BIDX,FL,IsAG,idx,CSTC,kVAR,zSTOM,AGF,FX1
 N tKEY,tKEYI,EXEFN,PRM1,PRM2,PRM3,NoPHN,IsIDX,DEFPRC,DEFCPRC,Q1,Q2,Q3
 N NIBX,FX2,Bidx,FOP,FFN,FFQ,DTSY,DTEY
 N TZpol,TZstat,TZwork,TZdatar,TZstc
 N @$$NEWVAR^IUSL,KSKD,SUM,CEN,CNT
 ; FLT - фильтры (ID,
 ; TABLN - вывод таблицы
 ; VARPL - поле является переменной
 ; IsAG - есть аггрегация полей
 D RBUFH^YIXMLRR(1)
 K ^BUF($J)
 D DOw
 D CLOSE^YIXMLRR
 I DS>DE D MSG^RWU("Начальная дата меньше конечной.") Q  
 S X=$$LCL^IUSER("rptusl","mindate")
 I X,(DS<($H-X))!(DS<($H-X)) D MSG^RWU("Указанные даты вне разрешенного периода.") Q 
 S NoPHN=+$$LCL^IUSER("rptusl","nophn")
 S DTSY=$$DI^DTUTL("01.01."_$P($$DT^DTUTL(DS),".",3))
 S DTEY=$$DI^DTUTL("31.12."_$P($$DT^DTUTL(DS),".",3))
 
 D PRETZR^IPAC
 S TZstc=$G(TZRBTN("stc")),TZstat=$G(TZRBTN("status"))
 S TZwork=$G(TZRBTN("work")),TZpol=$G(TZRBTN("pol"))
 S TZdatar=$G(TZRBTN("datar"))
 S DEFPRC=$$DEFPRC^IINSC("",DS,0),DEFCPRC=DEFPRC
 S idx=0
 S VR="" F  S VR=$O(^ZNF(VR)) Q:VR=""  D:'$D(VRL)!$D(VRL(VR))
 .S X=0
 .I $D(LPUL) S U="",X=1 F  S U=$O(LPUL(U)) Q:U=""  I $D(^ZNFI("l",U,VR)) S X=0 Q  ; подх. лпу
 .Q:X 
 .S OT="" F  S OT=$O(^ZNF(VR,OT)) Q:OT=""  D:'$D(OTL)!$D(OTL(OT))
 ..S DT=DS-1 F  S DT=$O(^ZNF(VR,OT,DT)) Q:DT=""!(DT>DE)  S ID="" F  S ID=$O(^ZNF(VR,OT,DT,ID)) Q:ID=""  D
 ...I $D(LPUL) S LPU=$G(^(ID,"l")) Q:LPU=""  Q:'$D(LPUL(LPU)) 
 ...S A=VR
 ...D DOproc
 
 D OWF^RWU(".xmlb"),W^RWU($G(^PP(0,2))_"<rptusl>")
 S R=^SRPTUSL(^JOB(%JOB,"rptusl","id"))
 S R=R_" "_$$TXTP^DTUTL(DS,DE)
 D WTAGDC^RWU("infolabel",R)
 D W^RWU("<table>")
 D DOout
 D W^RWU("</table></rptusl></nb_console>")
 D C^RWU
 
 K ^BUF($J)
 Q
DOw ; Decode report parameters
 N IsFLT,aG,FLIN
 M zSTOM=^cfg("stom-otd")
 S:$G(^cfg("stom-otd")) zSTOM(^("stom-otd"))=""
 S (tKEY,tKEYI)=""
 
 S NBC="nb_console"
 S DS=$G(XML(NBC,"rptusl","df")) S:DS="" DS=+$H
 S DE=$G(XML(NBC,"rptusl","dt")) S:DE="" DE=+$H
 S R=$G(XML(NBC,"rptusl","otd"))
 F I=1:1 S X=$P(R,"|",I) Q:X=""  S OTL(X)=""
 S R=$G(XML(NBC,"rptusl","spec"))
 F I=1:1 S X=$P(R,"|",I) Q:X=""  S SPL(X)=""
 S R=$G(XML(NBC,"rptusl","lpu"))
 F I=1:1 S X=$P(R,"|",I) Q:X=""  S LPUL(X)=""
 S R=$G(XML(NBC,"rptusl","vr"))
 F I=1:1 S X=$P($P(R,CR,I),"|",1) Q:X=""  S VRL(X)=""
 
 K NIBX
 S R=$TR($G(XML(NBC,"rptusl","pid")),"; ",",")
 F I=1:1:$L(R,",") S X=$P(R,",",I) S:X'="" NIBX(X)=""
 
 S X=$G(XML(NBC,"rptusl","cusls"))
 F FI=1:1 S FX=$P(X,CR,FI) Q:FX=""  S ^BUF($J,"f",0,"usl",FX)=""
 
 S R=$G(XML(NBC,"rptusl","tab")),BIDX=""
 F I=1:1 S X=$P(R,CR,I) Q:X=""  D
 .S IDX=$P(X,"|",1),FL=$G(^JOB(%JOB,"rptusl","t",IDX,"fl"))
 .S IsFLT=0,aG=0
 .I I>1 Q:FL="" 
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"pcls"))
 .S:X'="" FLT(IDX,"pcls")=X,IsFLT=1
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"ucls"))
 .S:X'="" FLT(IDX,"ucls")=X,IsFLT=1
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"fltexe"))
 .S:X'="" FLT(IDX,"fltexe")=X,IsFLT=1
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"dfnexe"))
 .S:X'="" FLT(IDX,"dfn")="s X="_X
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"usls"))
 .F FI=1:1 S FX=$P(X,CR,FI) Q:FX=""  S ^BUF($J,"f",IDX,"usl",FX)=""
 .S:$O(^BUF($J,"f",IDX,"usl",""))'="" FLT(IDX,"usls")=1,IsFLT=1
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"diag"))
 .F FI=1:1 S FX=$P(X,CR,FI) Q:FX=""  S ^BUF($J,"f",IDX,"diag",FX)=""
 .S:$O(^BUF($J,"f",IDX,"diag",""))'="" FLT(IDX,"diag")=1,IsFLT=1
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"acl")),idx=1
 .F FI=2:1 S FX=$P(X,CR,FI) Q:FX=""  S FX=$P(FX,"|",1) S:FX'="" FLT(IDX,"acu",idx)=FX,FLT(IDX,"acu")=idx,idx=idx+1,IsFLT=1
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"dofl"))
 .S:X'="" tKEY=$P(X,":",1),tKEYI=$P(X,":",2,9)
 .; приведение фильтров к четкой последовательности + перекодир.
 .S X=$G(^JOB(%JOB,"rptusl","t",IDX,"flt")),idx=1
 .F FI=2:1 S FX=$P(X,CR,FI) Q:FX=""  D
 ..S FX=$P(FX,"|",1) Q:FX="" 
 ..S FX=$$WD^TXTU(FX)
 ..S K=$P(FX,"@",1) I $E(K,1,2)="=#",$E(K,$L(K))="#" S $P(FX,"@",1)="="_(+$$DI^DTUTL($E(K,3,$L(K)-1))) ; decode #date#
 ..S K=$P(FX,"@",3) I $E(K,1,2)="=#",$E(K,$L(K))="#" S $P(FX,"@",3)="="_(+$$DI^DTUTL($E(K,3,$L(K)-1))) ; decode #date@
 ..S FLT(IDX,"flt",idx)=FX,FLT(IDX,"flt")=idx
 ..S idx=idx+1,IsFLT=1
 .D:I>1 
 ..S TABLN(I-1)=$G(^("flnm"))
 ..S X=$G(^("flagr"))
 ..S:X'="" TABLN(I-1,1)=X,aG=1
 ..S TABLN(I-1,2)=FL
 ..S TABLN(I-1,3)=IDX
 ..S:X'="" TABLN(I-1,4)="" ; есть фильтр или агрегатное поле
 ..I 'IsFLT,'aG S TABLN(I-1,10)=$S($E(FL,1,3)="NI4":2,1:1) ; фильтр и агрегат не может быть индексом  
 ..S X=$G(^("flsym"))
 ..S:X'="" TABLN(I-1,5)=X
 ..S X=$G(^("psumm"))
 ..S:X'="" TABLN(I-1,6)=X
 ..S X=$G(^("psummi"))
 ..S:X'="" TABLN(I-1,61)=X
 ..S X=$G(^("rfnx"))
 ..S:X'="" TABLN(I-1,7)=X
 ..S X=$G(^("rfnln"))
 ..S:X'="" TABLN(I-1,8)=X
 ..S X=$G(^("dfnexe"))
 ..S:X'="" TABLN(I-1,9)="s X="_X
 .I I>1,$D(FLT(IDX)) S TABLN(I-1,4)=""
 K NBC
 
 ; need idx counter
 S I="",IsIDX=1 F  S I=$O(TABLN(I)) Q:I=""  I $D(TABLN(I,1)) S IsIDX=0 Q 
 S (kVAR,FL)="" F  S FL=$O(^SRPTUSLM("out",FL)) Q:FL=""  I FL'="OT",FL'="VR",FL'="DT",FL'="ID" S kVAR=$S(kVAR="":"",1:kVAR_",")_FL
 S FL="" F  S FL=$O(^SRPTUSLM("prm",FL)) Q:FL=""  S kVAR=$S(kVAR="":"",1:kVAR_",")_FL
 Q
DOproc ; 
 K PCLS,ACLS,CSTC,PIDX,@kVAR
 D GETLT^IUSL(VR,DT,OT,ID)
 I $D(NIBX),'$D(NIBX(NI)) Q 
 Q:STAT="d" 
 I $D(SPL) S:'$D(SP) SP=$$SPEC^IKADRY(VR,DT) Q:'$D(SPL(SP))  
 S FLG=$G(FLG)
 S:FLG'="" FLG="|"_FLG_"|" S FLGl=$L(FLG)
 S DIA=$G(DIA),NI=$G(NI)
 S KSKD=1 S:$D(SKID) KSKD=SKID/100
 S PIDX=$S($G(ISTC)="":"",1:$$PIDX^IPAC(NI,ISTC,DT))
 S U="" F  S U=$O(UL(U)) Q:U=""  D
 .S CNT=UL(U)
 .Q:'$$DOflt(0) 
 .S BIDX=$S(IsIDX:idx,1:"")
 .S I="" F  S I=$O(TABLN(I)) Q:I=""  S FL=$$DOgetpl(TABLN(I,2)) D:$D(TABLN(I,10)) bidx(FL)
 .S:BIDX="" BIDX=idx ; linear
 .S ^BUF($J,0,BIDX)=""
 .S I="" F  S I=$O(TABLN(I)) Q:I=""  I $D(TABLN(I,4)),$$DOflt(TABLN(I,3)) S X=$G(^BUF($J,0,BIDX,I)),^BUF($J,0,BIDX,I)=$$DOagr(X,BIDX)
 .I tKEY'="" S I=$$DOgetpl(tKEY) S ^BUF($J,0,BIDX,"k")=I ; ключ
 .S:IsIDX idx=idx+1
 Q
bidx(X) ; make base index
 S Bidx=TABLN(I,10)
 I $D(TABLN(I,9)) X TABLN(I,9) ; S X=""
 S:Bidx=1 $P(BIDX,"|",I+1)=$E(X,1,64) ; обычные значения 
 S:Bidx=2 $P(BIDX,"|",I+1)=$E(X,1,99) ; текст. из пациента
 Q
DOflt(IDf) ; Фильтр по ID
 Q:'$D(FLT(IDf)) 1
 S (Q1,Q2)=0
 I $D(FLT(IDf,"ucls")) S FR=FLT(IDf,"ucls") S Q1=1 F FI=1:1 S FX=$P(FR,"|",FI) Q:FX=""  D  Q:Q1!Q2 
 .I $E(FX)'="!",FLG[("|"_FX_"|") S Q1=0 Q 
 .I $E(FX)="!",FLG'[("|"_$E(FX,2,999)_"|") S Q1=0
 Q:Q1 0
 I $D(FLT(IDf,"usls")),'$D(^BUF($J,"f",IDf,"usl",U)) Q 0 
 I $D(FLT(IDf,"diag")) Q:DIA="" 0 I '$D(^BUF($J,"f",IDf,"diag",DIA)) Q 0
 
 I 'PRC S CSTC=$S($D(CSTC):CSTC,$D(ISTC):ISTC,1:$$GETTZ^IPAC(NI,TZstc,DT)),PRC=+$$GET^IINSC(CSTC,"price",DT) S:'PRC PRC=DEFPRC
 S DEFCPRC=DEFPRC
 
 I $D(FLT(IDf,"pcls")) S QQ=0 D  Q:QQ 0
 .S:'$D(PCLS) PCLS=$$GET^IPRICE(U,"cls",PRC,DT) 
 .S FK=FLT(IDf,"pcls")
 .I PCLS="",FK'["!" S QQ=1 Q 
 .S PCLS="|"_PCLS_"|",(Q1,Q2,Q3)=0
 .F FI=1:1 S FX=$P(FK,"|",FI) Q:FX=""  D   
 ..I $E(FX)'="!" S Q3=1 I PCLS[("|"_FX_"|") S Q1=1 Q 
 ..I $E(FX)="!",PCLS[("|"_$E(FX,2,999)_"|") S Q2=1
 .I Q2 S QQ=1 Q 
 .I Q3,'Q1 S QQ=1 Q 
 
 S QQ=0
 I $D(FLT(IDf,"acu")) S:'$D(ACLS) ACLS=$$GET^IPRICE(U,"acu",PRC,DT) S QQ=1 Q:ACLS="" 0 D
 .S FR=FLT(IDf,"acu") 
 .F FI=1:1:FR I $$IsAclEq(ACLS,FLT(IDf,"acu",FI)) S QQ=0 Q 
 Q:QQ 0
 S QQ=0
 I $D(FLT(IDf,"fltexe")) S FK=FLT(IDf,"fltexe") I FK'="" S QQ=1 I @FK S QQ=0 ; произв. фильтр
 Q:QQ 0
 D:$D(FLT(IDf,"flt"))  ; программа фильтра
 .S FR=FLT(IDf,"flt")
 .F FI=1:1:FR D  Q:QQ 
 ..S FX=FLT(IDf,"flt",FI)
 ..S FX1=$P(FX,"@",1),FOP=$P(FX,"@",2),FX2=$P(FX,"@",3),FFN=$P(FX,"@",4)
 ..S FX1=$S(FX1="":"",$E(FX1)="=":$E(FX1,2,999),1:$$DOgetpl(FX1)),FFQ=1
 ..S FX2=$S(FX2="":"",$E(FX2)="=":$E(FX2,2,999),1:$$DOgetpl(FX2))
 ..S:FOP="" FOP="="
 ..I FOP="!" S FK=(FX1'=""),FFQ=0
 ..I FOP="F" S FK=";"_$TR(FX1,"|",";")_";"[(";"_FX2_";"),FFQ=0
 ..I FOP="FF" S FK=$$FLinFL^TXTU($TR(FX1,";","|"),$TR(FX2,";,","||")),FFQ=0
 ..I FOP="[]" S FK=$S(FX1="":0,1:$D(^BUF(FX2,FX1))),FFQ=0
 ..I FOP="'[]" S FK='$S(FX1="":0,1:$D(^BUF(FX2,FX1))),FFQ=0
 ..I FOP="[" S FK=$$UL^TXTU(FX1)[$$UL^TXTU(FX2),FFQ=0
 ..I FFQ,FOP="'F" S FK=";"_$TR(FX1,"|",";")_";"'[(";"_FX2_";"),FFQ=0
 ..X:FFQ "S FK=FX1"_FOP_"FX2"
 ..S:FI=1 X=FK
 ..I FFN="",'FK S QQ=1,X=0 Q 
 ..I FFN="и" S X=X&FK
 ..I FFN="или" S X=X!FK
 .S QQ='X
 Q:QQ 0
 Q 1
DOagr(X,KEY) ; агрегатная ф-ция
 S FN=$G(TABLN(I,1))
 I FN="" S RX=X,X=$$DOgetpl(TABLN(I,2)) Q:'$D(TABLN(I,9)) X X TABLN(I,9) Q X 
 I $D(TABLN(I,9)) S RX=X,X=$$DOgetpl(TABLN(I,2)) X TABLN(I,9) S RXX=RX,RX=X,X=RXX 
 I FN="COUNT" Q X+1
 S:'$D(TABLN(I,9)) RX=$$DOgetpl(TABLN(I,2))
 I FN="SET" Q RX
 I FN="SUM" Q X+RX
 I FN="MIN" Q $S(RX<X:RX,1:X)
 I FN="MAX" Q $S(RX>X:RX,1:X)
 I FN="FIRST" Q $S(X="":RX,1:X) 
 S X=RX,RX=""
 I FN="UCNT",X'="" S RX=$G(^BUF($J,"t","a",KEY,I)) I '$D(^(I,X)) S ^(X)="",RX=RX+1,^BUF($J,"t","a",KEY,I)=RX
 Q RX
DOgetpl(PL) ; Поле по наименованию
 I PL="COMM" S COMM=$G(COMM) Q COMM
 I PL="CRNC" S CRNC=$G(CRNC) Q CRNC
 I PL="CSTC" S:'$D(CSTC) CSTC=$S($D(ISTC):ISTC,1:$$GETTZ^IPAC(NI,TZstc,DT)) Q CSTC
