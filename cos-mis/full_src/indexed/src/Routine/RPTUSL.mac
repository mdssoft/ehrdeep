 I PL="CUlvo" S:'$D(LPU) LPU=$$GETPL^IUSL(VR,DT,OT,ID,"l") S:'$D(CUlvo) CUlvo=LPU_","_VR_","_OT Q CUlvo
 I PL="CUlvr" S:'$D(LPU) LPU=$$GETPL^IUSL(VR,DT,OT,ID,"l") S:'$D(CUlvr) CUlvr=LPU_","_VR Q CUlvr
 I PL="CUlvs" S:'$D(LPU) LPU=$$GETPL^IUSL(VR,DT,OT,ID,"l") S:'$D(CUlvs) CUlvs=LPU_","_VR_","_SP Q CUlvs
 I PL="NUfpos" S:'$D(NUfpos) NUfpos=$$fnFpos() Q NUfpos
 I PL="abon" S:'$D(abon) abon=$D(^BTPLS("stc",$$getSTC())) Q abon
 I PL="cenn" S:'$D(cenn) cenn=$$PRICEH^IPRICE(U,$$getPRC(),DT)*CNT Q cenn
 I PL="cenn1" S:'$D(cenn1) cenn1=$$PRICEH^IPRICE(U,DEFPRC,DT)*CNT Q cenn1
 I PL="cnt" S:'$D(cnt) cnt=CNT Q cnt
 I PL="dvid" S:'$D(dvid) dvid=$$GET^IINSC($$getSTC(),"dvid",DT) Q dvid
 I PL="dgtype" S:'$D(dgtype) dgtype=$$GET^IINSC($$getSTC(),"tp",DT) Q dgtype
 I PL="kv" S:'$D(kv) kv=$$GETPL^IUSL(VR,DT,OT,ID,"kv") Q kv
 I PL="naz" S:'$D(naz) naz=$$GETPL^IUSL(VR,DT,OT,ID,"f") Q naz
 I PL="nazid" S:'$D(nazid) nazid=$$GETPL^IUSL(VR,DT,OT,ID,"fex") Q nazid
 I PL="fnaz" S:'$D(fnaz) fnaz=$$fromVRI^INAZN($$DOgetpl("naz")) Q fnaz
