 I PL="nazdl" S:'$D(nazdl) nazdl=$$fromDT^INAZN($$DOgetpl("naz")),nazdl=$S(nazdl:DT-nazdl,1:0) Q nazdl 
 I PL="frap" S:'$D(frap) frap=$$GET^IPAC(NI,"frap",DT),frap=$S(frap="":$$get^IINSC($$getSTC(),"frap",DT),1:"") q frap
 I PL="fras" S:'$D(fras) fras=$$GET^IPAC(NI,"fras",DT),fras=$S(fras="":$$get^IINSC($$getSTC(),"fras",DT),1:"") q fras
 I PL="fpos" S:'$D(fpos) fpos=$$IsPRPA^IUSL(NI,OT,VR,DT,ID) Q fpos
 I PL="fusl" S:'$D(fusl) fusl=$$IsFUSL^IUSL(NI,U,VR,DT,OT,ID) Q fusl
