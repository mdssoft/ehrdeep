 I PL="month" s:'$D(month) month=$$MONTH^DTUTL(DT) q month
 I PL="upaytp" s:'$D(upaytp) upaytp=$$getPTP(NI,VR,DT,OT,ID) q upaytp
 I PL="upaydt" s:'$D(upaydt) upaydt=$$GETPL^IUSL(VR,DT,OT,ID,"p") q upaydt
