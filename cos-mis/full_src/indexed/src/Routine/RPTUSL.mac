 I PL="NI4o" S:'$D(NI4o) NI4o=$$GET^IPAC(NI,"fioo",DT) Q NI4o
 I PL="NI4pol" S:'$D(NI4pol) NI4pol=$$GETTZ^IPAC(NI,TZpol,DT) Q NI4pol
 I PL="NI4polis" S:'$D(NI4polis) NI4polis=$$GET^IPAC(NI,"polis"_PIDX,DT) Q NI4polis
 I PL="NI4df" S:'$D(NI4df) NI4df=$$GET^IPAC(NI,"dog_from"_PIDX,DT) Q NI4df
 I PL="NI4dt" S:'$D(NI4dt) NI4dt=$$GET^IPAC(NI,"dog_to"_PIDX,DT) Q NI4dt
 I PL="NI4prg" S:'$D(NI4prg) NI4prg=$TR($$GET^IPAC(NI,"prog"_PIDX,DT),"|",";") Q NI4prg
 I PL="NI4stat" S:'$D(NI4stat) NI4stat=$TR($$GETTZ^IPAC(NI,TZstat,DT),"|",";") Q NI4stat
 I PL="NI4wrk" S:'$D(NI4wrk) NI4wrk=$$GETTZ^IPAC(NI,TZwork,DT) Q NI4wrk
 I PL="NI4ush" S:'$D(NI4ush) NI4ush=$$GET^IPAC(NI,"ush",DT) Q NI4ush
 I PL="NI4rsource" S:'$D(NI4rsource) NI4rsource=$$GET^IPAC(NI,"rsource",DT) Q NI4rsource
 I PL="NI4psumm" S:'$D(NI4psumm) NI4psumm=$$GET^IPAC(NI,"psumm"_PIDX,DT) Q NI4psumm
 I PL="NI4sumlimit" S:'$D(NI4sumlimit) NI4sumlimit=$$GET^IPAC(NI,"sumlimit"_PIDX,DT) Q NI4sumlimit
 I PL="NI4stcdog" S:'$D(NI4stcdog) NI4stcdog=$$GET^IPAC(NI,"stcdog",DT) Q NI4stcdog
 I PL="NI4stcprg" S:'$D(NI4stcprg) NI4stcprg=$$GET^IPAC(NI,"stcprg",DT) Q NI4stcprg
 I PL="NI4email" S:'$D(NI4email) NI4email=$$GET^IPAC(NI,"email",DT) Q NI4email
 I PL="NI4crea" S:'$D(NI4crea) NI4crea=$$CREATED^IPAC(NI) Q NI4crea
 I PL="NI4vagent" S:'$D(NI4vagent) NI4vagent=$P($$GET^IPAC(NI,"agent",DT),"@",1) Q NI4vagent
 I PL="NI4cagent" S:'$D(NI4cagent) NI4cagent=$P($$GET^IPAC(NI,"agent",DT),"@",2,3) Q NI4cagent
 I PL="NI4ecagent" S:'$D(NI4ecagent) NI4ecagent=$P($$GET^IPAC(NI,"agent",DT),"@",4) Q NI4ecagent
 I PL="ntime" S:'$D(ntime) ntime=$$GET^IPRICE(U,"tim",$$getPRC(),DT)*CNT Q ntime
 I PL="nzub" S:'$D(nzub) nzub=$$GETPL^IUSL(VR,DT,OT,ID,"nz") Q nzub
 I PL="cntzub" S:'$D(nzub) nzub=$$GETPL^IUSL(VR,DT,OT,ID,"nz") S:'$D(cntzub) cntzub=$$NZCNT^ISTOM(nzub) Q cntzub
 I PL="rgd" S:'$D(rgd) rgd=$$GETPL^IUSL(VR,DT,OT,ID,"rgd") Q rgd
 I PL="sbs" S:'$D(sbs) sbs=$$GET^IPRICE(U,"scost",$$getPRC(),DT)*CNT Q sbs
 I PL="uslkc" S:'$D(uslkc) uslkc=$$GET^IPRICE(U,"kctr",$$getPRC(),DT)*CNT Q uslkc
 I PL="uetv" S:'$D(uetv) uetv=$$GET^IPRICE(U,"uetv",$$getPRC(),DT)*CNT Q uetv
 I PL="uetms" S:'$D(uetms) uetms=$$GET^IPRICE(U,"uetms",$$getPRC(),DT)*CNT Q uetms
 I PL="pgrp" S:'$D(pgrp) pgrp=$$GET^IPRICE(U,"grp",$$getPRC(),DT) Q pgrp
 I PL="summ" S:'$D(summ) summ=$S($D(UL(U,1)):UL(U,1),1:$$PRICEH^IPRICE(U,$$getPRC(),DT)*KSKD*CNT) Q summ
 I PL="summ1" S:'$D(summ) summ=$S($D(UL(U,1)):UL(U,1),1:$$PRICEH^IPRICE(U,$$getPRC(),DT)*KSKD*CNT) S summ1=$S('CNT:0,1:summ/CNT) Q summ1
 I PL="summz" S:'$D(summz) summz=$$ZRP^IUSL(VR,DT,OT,ID) Q summz
 I PL="bill" S:'$D(bill) bill=$$NOW^IBILL(NI,DT) Q bill
 I PL="cbill" S:'$D(cbill) cbill=$$NOW^IBILL(NI) Q cbill
 I PL="pmatt" S:'$D(pmatt) pmatt=$$cvPMATT() Q pmatt
 I PL="stom" S:'$D(stom) stom=$S($D(zSTOM(OT)):1,1:0) Q stom
 I PL="vusl" S:'$D(vusl) vusl=$$ISPL^IUSL(VR,DT,OT,ID,"v") Q vusl
 I PL="kss" S:'$D(kss) kss=+$S($D(KASS):KASS,1:$$GET^IINSC($S($D(CSTC):CSTC,1:$$DOgetpl("CSTC")),"dvid",DT)=3) Q kss
 I PL="zrp" S:'$D(zrp) zrp=($$GETPL^IUSL(VR,DT,OT,ID,"zrp")>0)!($O(^ZNFE(VR,OT,DT,ID,"zrp",""))'="") Q zrp
 I PL="cowrk" S:'$D(cowrk) cowrk=$TR($$GETPL^IUSL(VR,DT,OT,ID,"cw"),"|",";") Q cowrk
 I PL="grn" S:'$G(grn) grn=$$TDSC^IGRNL(NI,$$GETPL^IUSL(VR,DT,OT,ID,"g"))
 I PL="con" S:'$D(con) con=$P($$GETPL^IUSL(VR,DT,OT,ID,"c"),"|",3) Q con
 I PL="consum" S:'$D(consum) consum=$P($$GETPL^IUSL(VR,DT,OT,ID,"c"),"|",1)*CNT Q consum
 I PL="zak" S:'$D(zak) zak=$$GETPL^IUSL(VR,DT,OT,ID,"cu") Q zak
 I PL="codoms" S:'$D(codoms) codoms=$$GET^IPRICE(U,"oms",$$getPRC(),DT) Q codoms
 I PL="precode" S:'$D(precode) precode=$$GET^IPRICE(U,"ecode",$$getPRC(),DT) Q precode
 I PL="nds" S:'$D(nds) nds=$$GET^IPRICE(U,"nds",$$getPRC(),DT) Q nds
