 I PL="matnm" S:'$D(matnm) matnm=$$cvNMATT() Q matnm
 I PL="matwrh" S:'$D(matwrh) matwrh=$$cvWSMATT()*CNT Q matwrh
 I PL="ms" S:'$D(ms) ms=$P($G(^ZNF(VR,OT,DT)),"|",1),ms=$S(ms="":$$LASTMS^IUSL(VR,DT,OT,$G(^ZNF(VR,OT,DT,ID,"l"))),1:ms) Q ms
 I PL="kadry" S:'$D(kadry) kadry=$$KDR^IUSER() q kadry
 I PL="kspec" S:'$D(kspec) kspec=$$SPEC^IUSER() q kspec
