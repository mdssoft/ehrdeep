  D:WIDE WC^RWU("TICKET_ID:C:10	CARD_NUM:C:7	SURNAME:C:30	FIRST_NAME:C:15	PATRONYMIC:C:15	COM_SHORT:C:11	CON_SHORT:C:5	POLICY:C:50	IDC:C:5	T_DATE:D	BR_SHORT:C:2	SER_SHORT:C:20	QUANTITY:C:10	SER_LONG:C:254	COMENT:C:50	CLOCK_NUM:C:5	PRICE:N:19:4	SUMM:N:19:4	ACCOUNT:C:20	ACC_DATE:D")
 
