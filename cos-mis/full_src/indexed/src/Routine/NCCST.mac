 S:K'="" K="|"_$$GETPL^ISPRAV("patccst",K,"cfg")_"|"
 S diaK=$S(K["|diagcode|":1,1:+$G(^cfg("ccst","diagcode"))) ; раздельно код и диагноз
 S vrK=$S(K["|vrcode|":1,1:+$G(^cfg("ccst","vrcode"))) ; выводить только код врача
 s wrkK=$S(K'["|nowork|":1,1:'+$G(^cfg("ccst","nowork"))) ; не указ. место работы
 S aPRC=$S(K["|expprc|":1,1:+$G(^cfg("ccst","expprc"))) ; выводить прейскурант
 S fioK=$S(K["|fullfio|":1,1:+$G(^cfg("ccst","fullfio"))) ; полное ФИО
 S ocdiK=$S(K["|onlydcode|":1,1:+$G(^cfg("ccst","onlydcode"))) ; Только коды диагнозов
 
 S ZZ=$$GET^YDOCS(IDX,"nzub")
