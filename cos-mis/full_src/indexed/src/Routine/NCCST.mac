 ..D WC^RWU(CR_NI_" "_$$FIO^IPAC(NI,DT)_" ПОЛИС:"_$$GET^IPAC(NI,"polis",DT)) 
 ..S (SU,CU)=0
 ..S PIDX=$$PIDXN^IPAC(NI,DGN,DT)
 .;S CNA=$S($D(^CNAD(DGN,U)):^(U),$D(^CNAD("*",U)):^(U),1:"")
 .;S UA=$S($P(CNA,"|",1)'="":$P(CNA,"|",1),1:U) ; псевдоним
 .S CNT=$P(X,"|",7),CEN=$P(X,"|",8)
 .S:Pll D1=$P(U,",",1),D2=$P(U,",",2),K=$P(U,",",3)
 .S PRC=$P(X,"|",10)
 .S DIA=$E($P(X,"|",9),1,64),Z=DIA
 .S Z=$$DT2^DTUTL(DT)_"|"
 .S UU=$$GET^IPRICE(U,"ecode",PRC,DT) S:UU="" UU=U
 .S UU=$P(UU,".",1)_"_"_$P(UU,".",2,99)
 .S NM=$G(^CNRESO(U)) ; TODO move->^CNAD
 .S:NM="" NM=$$NAMEH^IPRICE(U,PRC,DT)
 .S PNI=NI,SU=CEN*CNT+SU,CU=CU+CNT
