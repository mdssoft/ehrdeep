 N PCNT S PCNT=0
 
 S FLG="|"_$$GET^YDOCS(IDX,"scflg")_"|",(fD,fS)=0
 S:FLG["|nodt|" fD=1 S:FLG["|nocen|" fS=1
 S fC=+$G(^cfg("nccst","cenn"))
 S prpF=$S(FLG["|prplst|":1,FLG["|prplstf|":2,1:0)
 
 S DGN=+$$GET^YDOCS(IDX,"dog"),D1=+$$GET^YDOCS(IDX,"date")
 S RSS=+$$GET^YDOCS(IDX,"rscsumm")
