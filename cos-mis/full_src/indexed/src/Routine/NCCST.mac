NCCST ; Создание приложений к счету [ 12/16/2023  0:49 AM ]
INIT 
 N R S R=+$D(^LOG(%LOG,"lcl","ccst"))
 D OWF^RWU(".xmlb"),W^RWU($G(^PP(0,2))_"<culist>")
 D:$D(^LCL("ccst",R,"aexec")) WTAGUC^RWU("bt_exp_view",^("aexec"))
 D W^RWU("<alg>|"_CR)
 D LSTs^NSPRAV("ccstalg") ; ccstalg=name|proc
 D W^RWU("</alg><flg>")
 D WC^RWU("ccprp|Расчет по предоплатному договору")
 D WC^RWU(CR_"nccprp|Не ограничивать предоплатный договор")
 D WC^RWU(CR_"prplst|Список по предоплатному договору")
 D WC^RWU(CR_"prplstf|Прикрепление по предоплатному договору")
 D WC^RWU(CR_"vu|Только виртуальные услуги")
 D WC^RWU(CR_"nvu|Только не виртуальные услуги")
 D WC^RWU(CR_"avu|Добавить услуги до суммы")
 D WC^RWU(CR_"nnul|Не включать нулевые услуги")
 D WC^RWU(CR_"nerr|Исключить ошибочные из счета")
 D WC^RWU(CR_"nodt|Не указывать дату услуг")
 D WC^RWU(CR_"nocen|Не указывать стоимость услуг")
 D WC^RWU(CR_"grn|Только по гарантийным письмам")
 D WC^RWU(CR_"ngrn|Не по гарантийным письмам")
 D WC^RWU(CR_"stom|Только стоматология")
 D WC^RWU(CR_"nstom|Без стоматологии")
 D WC^RWU(CR_"nrkl|Без статуса рекламации")
 D WC^RWU(CR_"nds|Услуги с НДС")
 D WC^RWU(CR_"cprc|Страховой прейскурант")
 D WC^RWU(CR_"ofbill|Оплата в офисе")
 D WC^RWU(CR_"nofra|Без франшизы")
 D WC^RWU(CR_"fra|С франшизой")
 D W^RWU("</flg><sellpu>")
 D LSTFIsys^YCONTR("") ; filials
 D W^RWU("</sellpu></culist></nb_console>"),C^RWU
 Q
LST(DGN,DS,DE,LPU,DEL) ; Вывод документов
 ; DEL - со статусом "удаленные"
 N DTP,DOC,X,CCR,A,U
 S DS=$$DIH^DTUTL(DS),DE=$$DIH^DTUTL(DE),DEL=+$G(DEL)
 S DTP=$$FNDTP^YDOCTP("Приложение к счету"),CCR="",LPU=$G(LPU)
 D OWF^RWU(".txt")
 I $L(DTP) S DOC="" F  S DOC=$O(^CDOCI("type",DTP,DOC)) Q:DOC=""  D
 .S X=$P(DOC,",",1) Q:X<DS!(X>DE) 
 .I DGN'="",$$GET^YDOCS(DOC,"dog")'=DGN Q 
 .I 'DEL,$$GET^YDOCS(DOC,"del") Q  
 .I DEL,'$$GET^YDOCS(DOC,"del") Q 
 .S U=$$GET^YDOCS(DOC,"user")
 .I LPU'="",U["@",$P(U,"@",2)'=LPU Q 
 .S A=$$DT2^DTUTL($$GET^YDOCS(DOC,"date"))_", "_U
 .D WC^RWU(CCR_DOC_"~"_A_"|"_$$GET^YDOCS(DOC,"nm")) S CCR=CR
 D C^RWU
 Q
LTAB(IDX) ; Вывод приложения
 N X,FYDOCS,DT,NI,U,ND,fH,D1,D2,K,CNA,UN,DGN,UA,fLP
 S IDX=$P(IDX,"~",1)
 D OWF^RWU(".xmlb"),W^RWU($G(^PP(0,2))_"<culist>")
 S K=+$$GET^YDOCS(IDX,"date"),DGN=$$GET^YDOCS(IDX,"dog")
 S X=$$GET^IINSC(DGN,"pccst",K)
 S:X'="" X=$P($$GET^ISPRAV("patccst",X),"|",3,99)
 S:X="" X=$$LCL^NUSER("ccst","aexec")
 S fLP=$G(^cfg("nccst","ltab-lpu"))
 D WTAGUC^RWU("bt_exp_view",X)
 D W^RWU("<vtab"_$S(fLP:" default=""Дата:1000;Пациент:2500;Услуга:3600;К-во:600;Сумма:900;Диагноз:1000;Филиал:2000""",1:"")_">")
 G:'$$CHECK^YDOCS(IDX) LTABEND D ORSTR^YDOCS
 S ND=IDX,fH=1 D LTABPRC
LTABEND 
 D W^RWU("</vtab></culist></nb_console>"),C^RWU
 Q
ODOC ; View in doc. repository ND - document ID
 N X,FYDOCS,DT,NI,U,fH,D1,D2,K,CNA,UN,DGN,UA
 S fH=0,DGN=$$GET^YDOCS(ND,"dog")
 D ORSTR^YDOCS
 D WC^RWU("Дата|Пациент|Услуга|К-во|Сумма|Диагноз"_$S(fLP:"|ЛПУ",1:""))
LTABPRC 
 N uF,KEY,CNT,VR,OT,ID,LP
 S uF=$G(^cfg("nccst","wucode"))
 F  S X=$$RSTR^YDOCS(ND) Q:FYDOCS=""  D
 .S DT=$P(X,"|",1),NI=$P(X,"|",5),U=$P(X,"|",6)
 .I DT="p" D  Q 
 ..S D1=$P(U,",",1),D2=$P(U,",",2),K=$P(U,",",3)
 ..S U="Прикрепление с "_$$DT^DTUTL(D1)_" по "_$$DT^DTUTL(D2)_", "_K_" дней"
 ..D WC^RWU(CR_$S(fH:"|",1:"")_"|"_NI_" "_$$FIOSH^IPAC(NI,D1)_"|"_U_"|"_$P(X,"|",7)_"|"_($P(X,"|",7)*$P(X,"|",8)))
 .S CNA=$S($D(^CNAD(DGN,U)):^(U),$D(^CNAD("*",U)):^(U),1:"")
 .S UA=$S($P(CNA,"|",1)'="":$P(CNA,"|",1),1:U)
 .S UN=$S($P(CNA,"|",2)'="":$P(CNA,"|",2),1:$$NAMEH^IPRICE(U,$P(X,"|",10),DT))
 .S:uF UN=UA_" "_UN
 .S KEY=$TR($P(X,"|",1,4),"|","@")
 .S VR=$P(X,"|",2),OT=$P(X,"|",3),ID=$P(X,"|",4)
 .S:$$GETFLG^IUSL(VR,DT,OT,ID)["rkl" $P(KEY,"@",5)=2
 .S:fLP LP=$$GETPL^IUSL(VR,DT,OT,ID,"l")
 .S KEY=$S(fH:KEY_"|",1:""),CNT=$P(X,"|",7)
 .D WC^RWU(CR_KEY_$$TAG^TXTU($$DT^DTUTL(DT)_"|"_NI_" "_$$FIOSH^IPAC(NI,DT)_"|"_UN_"|"_CNT_"|"_(CNT*$P(X,"|",8))_"|"_$$NAME^YMKB10($P(X,"|",9)))_$S(fLP:"|"_$$NAME^ICONTR(LP),1:""))
 Q
LDEX(IDX) 
 N X,FYDOCS,DT,NI,U,UA,PNI,A,W,VR,SU,CU,SUA,CUA,TIT,NDS,NND,DGN,CNT,CEN
 N fD,fS,fC,D1,D2,Pll,UN,K,FLG,prpF,diaK,DIA,CNA,PIDX,ZZ,wrkK,Z,PRC,aPRC
 N vrK,fioK,ocdiK,GRN,RS,RSS,PLS,fLP,fOMS
 D OWF^RWU(".txt")
 D W^RWU("<?xml version=""1.0"" encoding=""Windows-1251""?>")
 G:'$$CHECK^YDOCS(IDX) LDEXEND
 S FLG="|"_$$GET^YDOCS(IDX,"scflg")_"|",(fD,fS)=0
 S:FLG["|nodt|" fD=1 S:FLG["|nocen|" fS=1
 S fC=+$G(^cfg("nccst","cenn"))
 S fLP=$G(^cfg("nccst","ltab-lpu"))
 S fOMS=$G(^cfg("nccst","exp-coms"))
 S prpF=$S(FLG["|prplst|":1,FLG["|prplstf|":2,1:0)
 
 S DGN=+$$GET^YDOCS(IDX,"dog"),D1=+$$GET^YDOCS(IDX,"date")
 S RSS=+$$GET^YDOCS(IDX,"rscsumm")
 S K=$$GET^IINSC(DGN,"pccst",D1)
 S:K'="" K="|"_$$GETPL^ISPRAV("patccst",K,"cfg")_"|"
 S diaK=$S(K["|diagcode|":1,1:+$G(^cfg("ccst","diagcode"))) ; раздельно код и диагноз
 S vrK=$S(K["|vrcode|":1,1:+$G(^cfg("ccst","vrcode"))) ; выводить только код врача
 s wrkK=$S(K'["|nowork|":1,1:'+$G(^cfg("ccst","nowork"))) ; не указ. место работы
 S aPRC=$S(K["|expprc|":1,1:+$G(^cfg("ccst","expprc"))) ; выводить прейскурант
 S fioK=$S(K["|fullfio|":1,1:+$G(^cfg("ccst","fullfio"))) ; полное ФИО
 S ocdiK=$S(K["|onlydcode|":1,1:+$G(^cfg("ccst","onlydcode"))) ; Только коды диагнозов
 
 S ZZ=$$GET^YDOCS(IDX,"nzub")
 D W^RWU("<data_exchange>"_CR_"<format>")
 D WC^RWU("<total column=""CNT|SUMM"" name=""Кол-во|Сумма"" type=""NUM|MONEY""></total>")
 
 S A="<item column=""NIB|"_$S(fioK:"FIO",1:"FAM|IM|OT")_"|POLIS|PDATE"
 S:wrkK A=A_"|MR"
 S A=A_""" name=""№ И.Б.|"_$S(fioK:"Ф.И.О.",1:"Фамилия|Имя|Отчество")_"|Полис|Срок полиса"
 S:wrkK A=A_"|Место работы"
 S A=A_""" type=""NUM|"_$S(fioK:"CHAR(120)",1:"CHAR(40)|CHAR(40)|CHAR(40)")_"|CHAR(30)|DATE"
 S:wrkK A=A_"|NUM"
 D WC^RWU(A_""">")
 
 S A=$S(fD:"",1:"DATA|")_"KOD|UNAME|CNT|"
 S:'fS A=A_$S(fC:"CENN|",1:"")_"SUMM|"_$S(RSS:"RSUMM|",1:"")
 S A=A_$S(diaK:"DIAG|DIAGNAME",1:"DIAG")
 S:ZZ A=A_"|TOOTH"
 S A=A_"|VR"
 S A=A_"|SPEC"
 S:aPRC A=A_"|PRICE"
 S:fLP A=A_"|LPU"
 S:fOMS A=A_"|OMS"
 S A=A_""" name="""_$S(fD:"",1:"Дата|") 
 S A=A_"Код услуги|Наименование услуги|Кол-во|"
 S:'fS A=A_$S(fC:"Цена|",1:"")_"Сумма|"_$S(RSS:"Базовая цена|",1:"")
 S A=A_$S(diaK:"МКБ-10|Диагноз",1:"Диагноз")
 S:ZZ A=A_"|№ зубов"
 S A=A_"|Исполнитель"
 S A=A_"|Специальность"
 S:aPRC A=A_"|Прейскурант"
 S:fLP A=A_"|Филиал"
 S:fOMS A=A_"|Код ОМС"
 S A=A_""" type="""_$S(fD:"",1:"DATE|")
 S A=A_"CHAR(10)|CHAR(200)|NUM|"
 S:'fS A=A_$S(fC:"MONEY|",1:"")_"MONEY|"
 S A=A_$S(diaK:"CHAR(64)|CHAR(255)",1:"CHAR(64)")
 S:ZZ A=A_"|CHAR(60)"
 S A=A_"|CHAR(60)" ; vr
 S A=A_"|CHAR(60)" ; spec
 S:aPRC A=A_"|NUM"
 S:fLP A=A_"|CHAR(60)"
 S:fOMS A=A_"|CHAR(60)" ; multiple codes
 D WC^RWU("<item column="""_A_"""></item>")
 
 D W^RWU("</item></format><data>")
 S TIT=$$GET^YDOCS(IDX,"nm")
 S X=$G(^cfg("nccst","utitle"))
 S:X="" X="Реестр оказанных услуг"
 S A=$G(^cfg("nccst","ptitle"))
 S:A="" A="Реестр прикрепленных пациентов"
 D WTAGC^RWU("title",$S(prpF:A,1:X)_", "_TIT)
 D ORSTR^YDOCS
 S PNI="",(NDS,Pll,SUA,CUA,SU,CU)=0
 F  S X=$$RSTR^YDOCS(IDX) Q:FYDOCS=""  D
 .Q:$P(X,"|",5)=""  ; todo - не должно быть нулевых
 .S DT=$P(X,"|",1),NI=$P(X,"|",5),U=$P(X,"|",6),VR=$P(X,"|",2)
 .S GRN=$P(X,"|",13)
 .S:DT="p" DT=+$H,Pll=1 
 .I PNI'=NI D
 ..I $D(SU) D WTAG^RWU("total",CU_"|"_SU),WTAGC^RWU("footer","Итого "_$S(prpF:"пациентов ",1:"услуг ")_CU_" на сумму "_SU)
 ..S (SU,CU)=0
 ..S PIDX=$$PIDXN^IPAC(NI,DGN,DT)
 ..S A=$S($L(PNI):"</item>",1:"")
 ..I wrkK S W=+$$GET^IPAC(NI,"work",DT) S:'$D(^M(5,W))!('W) W=""
 ..S A=A_"<item>"_NI_"|"_$S(fioK:$$FIO^IPAC(NI,DT),1:$$GET^IPAC(NI,"fiof",DT)_"|"_$$GET^IPAC(NI,"fioi",DT)_"|"_$$GET^IPAC(NI,"fioo",DT))
 ..S PLS=""
 ..I GRN'="" S PLS=$$GET^IGRNL(NI,GRN,"polis") ; TODO -настройка условия
 ..I GRN'="",PIDX=-1 D WC^RWU(A_"|"_PLS_"|"_$$DT^DTUTL($$DTO^IGRNL(NI,GRN))_$S(wrkK:"|"_W,1:"")) Q 
 ..S:PIDX=-1 PIDX=""
 ..S:PLS="" PLS=$$GET^IPAC(NI,"polis"_PIDX,DT)
 ..D WC^RWU(A_"|"_PLS_"|"_$$GETE^IPAC(NI,"dog_to"_PIDX,DT)_$S(wrkK:"|"_W,1:""))
 .S CNA=$S($D(^CNAD(DGN,U)):^(U),$D(^CNAD("*",U)):^(U),1:"")
 .S UA=$S($P(CNA,"|",1)'="":$P(CNA,"|",1),1:U) ; псевдоним
 .S CNT=$P(X,"|",7),CEN=$P(X,"|",8)
 .S A=$S(fS:"",1:$S(fC:CEN_"|",1:"")_(CNT*CEN)_"|")_$S(RSS:(CNT*$P(X,"|",14))_"|",1:"")
 .S:Pll D1=$P(U,",",1),D2=$P(U,",",2),K=$P(U,",",3)
 .S PRC=$P(X,"|",10)
 .S UN=$S(Pll:"Прикрепление с "_$$DT^DTUTL(D1)_" по "_$$DT^DTUTL(D2)_", "_K_" дней",$P(CNA,"|",2)'="":$P(CNA,"|",2),1:$$NAMEH^IPRICE(U,PRC,DT))
 .S UN=$E(UN,1,999)
 .S UN=$E(UN,1,199)
 .S DIA=$E($P(X,"|",9),1,64),Z=DIA
 .S:ocdiK DIA=$TR(DIA,","," ")
 .S DIA=$S(diaK:DIA_"|"_$E($$NAME^YMKB10(Z),1,255),1:DIA)
 .S Z=$S(fD:UA,Pll:"|",1:$$DT^DTUTL(DT)_"|"_UA)_"|"
 .S Z=Z_UN_"|"_CNT_"|"_A_DIA_"|"
 .S:ZZ Z=Z_$P(X,"|",11)_"|"
 .S Z=Z_$S(Pll:"",1:$S(vrK=2:"",vrK:VR,1:$E(VR_" "_$$FIOSH^IKADRY(VR,DT),1,60)))
 .S Z=Z_"|"_$P(X,"|",12)
 .S:aPRC Z=Z_"|"_PRC
 .S:fLP Z=Z_"|"_$$NAME^ICONTR($$GETPL^IUSL(VR,DT,$P(X,"|",3),$P(X,"|",4),"l"))
 .S:fOMS Z=Z_"|"_$$GET^IPRICE(U,"oms",PRC,DT)
 .D WTAGC^RWU("item",Z)
 .S PNI=NI,SU=CEN*CNT+$G(SU),CU=$G(CU)+CNT
 .S SUA=CEN*CNT+$G(SUA),CUA=$G(CUA)+CNT
 .Q:Pll 
 .S NND=$$GET^IPRICE(U,"nds",PRC,DT) Q:NND=""
 .S NDS=CEN*CNT*100/NND+NDS
 I SU!CU D WTAG^RWU("total",CU_"|"_SU),WTAGC^RWU("footer","Итого услуг "_CU_" на сумму "_SU)
 D W^RWU("</item>")
 D W^RWU("<footer>")
 D WC^RWU($$^I("ifname")_CR)
 S X=$G(^cfg("nccst","footertext"))
 S Z=$S(prpF=2:"прикрепление.",prpF:"прикрепленных пациентов.",1:"выполненные Медицинские Услуги.")
 ; Произвольный текст в подвале счета 
 I X'="" D  G LDEXfoo
 .N LL
 .D FREQ^ITEMPLT("LL")
 .S LL("object")=Z,LL("nds")=NDS,LL("summ")=SUA
 .S X=$$AST^ITEMPLT(X,"LL")
 .D WC^RWU(X)
 
 S X='+$G(^cfg("nccst","nofooter"))
 D:X WC^RWU("Итоговый счет за "_Z_CR)
 D:X WC^RWU(CR_"для "_TIT_CR_CR) ; TODO
 S X='+$G(^cfg("nccst","nofcnt"))
 D:X WC^RWU("Количество "_$S(prpF:"прикрепленных лиц: ",1:"выполненных услуг: ")_CUA_" шт."_CR)
 D WC^RWU("Стоимость"_$S(prpF:" прикрепления: ",1:" выполненных услуг: ")_SUA_" руб."_CR)
 D:NDS WC^RWU(", в том числе НДС: "_NDS_" руб."_CR)
 D W^RWU(CR)
 D:$G(^cfg("nccst","igldr")) WC^RWU(CR_"Генеральный директор ________________ / "_$$^I("igldr")_" /"_CR)
 D:$G(^cfg("nccst","icmdr")) WC^RWU(CR_"Коммерческий директор ________________ / "_$$^I("icmdr")_" /"_CR)
 D:$G(^cfg("nccst","iglvr")) WC^RWU(CR_$$^I("iglvrd")_" ________________ / "_$$^I("iglvr")_" /"_CR)
 D:$G(^cfg("nccst","iglbh")) WC^RWU(CR_$$^I("iglbhd")_" ________________ / "_$$^I("iglbh")_" /"_CR)
LDEXfoo 
 D W^RWU("</footer>")
LDEXEND D W^RWU("</data></data_exchange>"),C^RWU
 Q
LPRN(IDX) 
 N X,FYDOCS,DT,NI,U,UA,PNI,A,W,VR,SU,CU,SUA,CUA,TIT,NDS,NND,DGN,CNT,CEN
 N fD,fS,fC,D1,D2,Pll,UN,K,FLG,prpF,diaK,DIA,CNA,PIDX,ZZ,wrkK,Z,PRC,aPRC,PLS,PCNT
 N vrK,fioK,ocdiK,GRN,RS,RSS,DDS,DDE,AA
 G:'$$CHECK^YDOCS(IDX) LPEXEND
 S FLG="|"_$$GET^YDOCS(IDX,"scflg")_"|",(fD,fS)=0
 S:FLG["|nodt|" fD=1 S:FLG["|nocen|" fS=1
 S fC=+$G(^cfg("nccst","cenn"))
 S prpF=$S(FLG["|prplst|":1,FLG["|prplstf|":2,1:0)
 
 S DGN=+$$GET^YDOCS(IDX,"dog"),D1=+$$GET^YDOCS(IDX,"date")
 S RSS=+$$GET^YDOCS(IDX,"rscsumm")
 S DDS=+$$GET^YDOCS(IDX,"df"),DDE=+$$GET^YDOCS(IDX,"dt")
 S K=$$GET^IINSC(DGN,"pccst",D1)
 D OWF^RWU(".xml")
 D OPEN^ISTREP("Приложение к счету "_$$TAG^TXTU($TR($$NAME^IINSC(DGN),"""","'")))
 D FONT^ISTREP(1,"Times New Roman",7)
 D FONT^ISTREP(2,"Arial",11)
 D FONT^ISTREP(3,"Arial",11,"b")
 D FONT^ISTREP(4,"Times New Roman",8)
 D FONT^ISTREP(5,"Times New Roman",8,"b")
 D CSTART^ISTREP("l","","10|10|10|10")
 
 D LD^ISTREP("Приложение к Акту к счету № ________ от ___.___."_$$YEAR^DTUTL(+$H),2,"c")
 D LD^ISTREP("о выполнении работ оказанных за период с "_$$DT^DTUTL(DDS)_" по "_$$DT^DTUTL(DDE),2,"c")
 D LD^ISTREP("Заказчик/страховщик "_$$NAME^IINSC(DGN),2,"c")
 D LD^ISTREP("код договора "_$$GET^IINSC(DGN,"dognum",+$H),2,"c")
 D H^ISTREP(2)
 
 S:K'="" K="|"_$$GETPL^ISPRAV("patccst",K,"cfg")_"|"
 S diaK=$S(K["|diagcode|":1,1:+$G(^cfg("ccst","diagcode"))) ; раздельно код и диагноз
 S vrK=$S(K["|vrcode|":1,1:+$G(^cfg("ccst","vrcode"))) ; выводить только код врача
 s wrkK=$S(K'["|nowork|":1,1:'+$G(^cfg("ccst","nowork"))) ; не указ. место работы
 S aPRC=$S(K["|expprc|":1,1:+$G(^cfg("ccst","expprc"))) ; выводить прейскурант
 S fioK=$S(K["|fullfio|":1,1:+$G(^cfg("ccst","fullfio"))) ; полное ФИО
 S ocdiK=$S(K["|onlydcode|":1,1:+$G(^cfg("ccst","onlydcode"))) ; Только коды диагнозов
 
 S ZZ=$$GET^YDOCS(IDX,"nzub")
 N WW
 S WW="15|15|45|30|22|99|7|18|18"
 S AA="||l|||l|||"
 D TAB^ISTREP("Дата|Карта|Ф.И.О.|Полис|Код|Услуга|К-во|Цена|Стоимость",WW,"1.5f",4)
 
 D ORSTR^YDOCS
 S PNI="",(NDS,Pll,SUA,CUA,SU,CU,PCNT)=0
 F  S X=$$RSTR^YDOCS(IDX) Q:FYDOCS=""  D
 .Q:$P(X,"|",5)=""  ; todo - не должно быть нулевых
 .S DT=$P(X,"|",1),NI=$P(X,"|",5),U=$P(X,"|",6),VR=$P(X,"|",2)
 .S GRN=$P(X,"|",13)
 .S:DT="p" DT=+$H,Pll=1 
 .I PNI'=NI D
 ..I PNI'="" D TAB^ISTREP("ИТОГО|по|"_$$FIOSH^IPAC(PNI)_"||||||"_SU,WW,"1.5f") S PNI="",PCNT=PCNT+1
 ..S (SU,CU)=0
 .S PIDX=$$PIDXN^IPAC(NI,DGN,DT)
 .;S CNA=$S($D(^CNAD(DGN,U)):^(U),$D(^CNAD("*",U)):^(U),1:"")
 .;S UA=$S($P(CNA,"|",1)'="":$P(CNA,"|",1),1:U) ; псевдоним
 .S CNT=$P(X,"|",7),CEN=$P(X,"|",8)
 .;S A=$S(fS:"",1:$S(fC:CEN_"|",1:"")_(CNT*CEN)_"|")_$S(RSS:(CNT*$P(X,"|",14))_"|",1:"")
 .S:Pll D1=$P(U,",",1),D2=$P(U,",",2),K=$P(U,",",3)
 .S PRC=$P(X,"|",10)
 .S DIA=$E($P(X,"|",9),1,64),Z=DIA
 .S Z=$$DT2^DTUTL(DT)_"|"
 .S Z=Z_NI_"|"_$$FIOSH^IPAC(NI,DT)_"|"_$$GET^IPAC(NI,"polis"_PIDX,DT)_"|"
 .S UU=$$GET^IPRICE(U,"ecode",PRC,DT) S:UU="" UU=U
 .S UU=$P(UU,".",1)_"_"_$P(UU,".",2,99)
 .S Z=Z_UU_"|"_$$NAMEH^IPRICE(U,PRC,DT)_"|"
 .S PNI=NI,SU=CEN*CNT+$G(SU),CU=$G(CU)+CNT
 .S SUA=CEN*CNT+$G(SUA),CUA=$G(CUA)+CNT
 .S Z=Z_CNT_"|"_CEN_"|"_(CEN*CNT)
 .D TAB^ISTREP(Z,WW,"1.5f",,,AA)
 .Q:Pll 
 .S NND=$$GET^IPRICE(U,"nds",PRC,DT) Q:NND=""
 .S NDS=CEN*CNT*100/NND+NDS
 I PNI'="" D TAB^ISTREP("ИТОГО|по|"_$$FIOSH^IPAC(PNI)_"||||||"_SU,WW,"1.5f") S PNI="",PCNT=PCNT+1
 D:$G(^cfg("nccst","totalp")) WC^RWU("<p ><d>Всего пациентов: "_PCNT_"</d></p>")
 D H^ISTREP(3)
 D WC^RWU("<p f=""5""><d>ВСЕГО: "_SUA_" руб. (</d><f>$moneytowords:"_SUA_":руб.:коп.</f><d>)</d></p>")
 D:NDS WC^RWU("<p f=""5""><d>В том числе НДС: "_NDS_" руб. </d></p>")
 D H^ISTREP(5)
 D LD^ISTREP("От Исполнителя",5)
 D H^ISTREP(3)
 D:$G(^cfg("nccst","iglvr")) LD^ISTREP($$^I("iglvrd")_" __________________("_$$^I("iglvr")_")",5)
 D H^ISTREP(3)
 D:$G(^cfg("nccst","iglbh")) LD^ISTREP($$^I("iglbhd")_" __________________("_$$^I("iglbh")_")",5)
LPEXEND 
 D CEND^ISTREP,CLOSE^ISTREP
 D C^RWU
 Q
LXSLPT(IDX) 
 N X,FYDOCS,DT,NI,U,UA,PNI,A,W,VR,SU,CU,SUA,CUA,TIT,NDS,NND,DGN,CNT,CEN
 N fD,fS,fC,D1,D2,Pll,UN,K,FLG,prpF,diaK,DIA,CNA,PIDX,ZZ,wrkK,Z,PRC,aPRC
 N vrK,fioK,ocdiK,PLS,GRN,RS,RSS,DDS,DDE,KPT,REZ,JJ,JK,ZZ
 G:'$$CHECK^YDOCS(IDX) LPEXEND
 S FLG="|"_$$GET^YDOCS(IDX,"scflg")_"|",(fD,fS)=0
 S:FLG["|nodt|" fD=1 S:FLG["|nocen|" fS=1
 S fC=+$G(^cfg("nccst","cenn"))
 S prpF=$S(FLG["|prplst|":1,FLG["|prplstf|":2,1:0)
 
 S DGN=+$$GET^YDOCS(IDX,"dog"),D1=+$$GET^YDOCS(IDX,"date")
 S RSS=+$$GET^YDOCS(IDX,"rscsumm")
 S DDS=+$$GET^YDOCS(IDX,"df"),DDE=+$$GET^YDOCS(IDX,"dt")
 S K=$$GET^IINSC(DGN,"pccst",D1)
 
 ;S KPT=$G(^CCSTE(DGN)) S:KPT="" KPT=$G(^CCSTE("*"))
 
 D:DGN=7
 .D wx("A6","За период с "_$$DT^DTUTL(DDS)_" по "_$$DT^DTUTL(DDE))
 .S JJ=9
 
 D:DGN'=7
 .D wx("A3","За период с "_$$DT^DTUTL(DDS)_" по "_$$DT^DTUTL(DDE))
 .D wx("D2",$$NAME^IINSC(DGN))
 .S JJ=6
 
 S JK=1
 
 D ORSTR^YDOCS
 S PNI="",(NDS,Pll,SUA,CUA,SU,CU)=0
 F  S X=$$RSTR^YDOCS(IDX) Q:FYDOCS=""  D
 .Q:$P(X,"|",5)=""  ; todo - не должно быть нулевых
 .S DT=$P(X,"|",1),NI=$P(X,"|",5),U=$P(X,"|",6),VR=$P(X,"|",2)
 .S GRN=$P(X,"|",13),ZZ=$P(X,"|",11)
 .S:DT="p" DT=+$H,Pll=1 
 .I PNI'=NI D
 ..I PNI'="" D:DGN=7 pde7 D:DGN'=7 pdeA S PNI=""
 ..S (SU,CU)=0
 ..S PIDX=$$PIDXN^IPAC(NI,DGN,DT)
 .;S CNA=$S($D(^CNAD(DGN,U)):^(U),$D(^CNAD("*",U)):^(U),1:"")
 .;S UA=$S($P(CNA,"|",1)'="":$P(CNA,"|",1),1:U) ; псевдоним
 .S CNT=$P(X,"|",7),CEN=$P(X,"|",8)
 .;S A=$S(fS:"",1:$S(fC:CEN_"|",1:"")_(CNT*CEN)_"|")_$S(RSS:(CNT*$P(X,"|",14))_"|",1:"")
 .S:Pll D1=$P(U,",",1),D2=$P(U,",",2),K=$P(U,",",3)
 .S PRC=$P(X,"|",10)
 .S DIA=$E($P(X,"|",9),1,64),Z=DIA
 .S UU=$$GET^IPRICE(U,"ecode",PRC,DT) S:UU="" UU=U
 .S UU=$P(UU,".",1)_"_"_$P(UU,".",2,99)
 .S PNI=NI,SU=CEN*CNT+$G(SU),CU=$G(CU)+CNT
 .S SUA=CEN*CNT+$G(SUA),CUA=$G(CUA)+CNT
 .D:DGN=7 pd7
 .D:DGN'=7 pdA
 .S JK=JK+1
 I PNI'="" D:DGN=7 pde7 D:DGN'=7 pdeA
 
 d wx("H"_JJ,"ИТОГО")
 d wx("K"_JJ,SUA)
 S JJ=JJ+2
 d wx("A"_JJ,"Сумма к оплате: "_$$TXTSUM^TXTU(SUA))
 S JJ=JJ+2
 d wx("A"_JJ,"Представитель ЛПУ ФИО______________________________/__________________/")
 S JJ=JJ+2
 d wx("A"_JJ,"М.П.")
 
 D:DGN=7 MAKE^IDOCGEN("sogaz.xlsx","REZ","xlsx")
 D:DGN'=7 MAKE^IDOCGEN("dms1.xlsx","REZ","xlsx")
 ;K ^KKK m ^KKK=REZ
 Q
pd7 
 d wx("A"_JJ,JK)
 d wx("B"_JJ,$$FIO^IPAC(NI))
 d wx("C"_JJ,$$GET^IPAC(NI,"polis"_PIDX,DT))
 d wx("D"_JJ,"") ; гп
 d wx("E"_JJ,$$DT^DTUTL(DT))
 d wx("F"_JJ,"")
 d wx("G"_JJ,U)
 d wx("H"_JJ,$$NAMEH^IPRICE(U,PRC,DT))
 d wx("I"_JJ,CNT)
 d wx("J"_JJ,DIA)
 d wx("K"_JJ,CEN*CNT)
 S JJ=JJ+1
 Q
pdA 
 d wx("A"_JJ,JK)
 d wx("B"_JJ,$$FIO^IPAC(NI))
 d wx("C"_JJ,$$GET^IPAC(NI,"polis"_PIDX,DT))
 d wx("D"_JJ,"") ; гп
 d wx("E"_JJ,$$DT^DTUTL(DT))
 d wx("F"_JJ,"")
 d wx("G"_JJ,U)
 d wx("H"_JJ,$$NAMEH^IPRICE(U,PRC,DT))
 d wx("I"_JJ,CNT)
 d wx("J"_JJ,DIA)
 d wx("K"_JJ,$$FIO^IKADRY(VR))
 d wx("L"_JJ,ZZ)
 d wx("M"_JJ,CEN*CNT)
 ;d wx("K"_JJ,CEN*CNT)
 S JJ=JJ+1
 Q
pde7 
 d wx("B"_JJ,"ИТОГО к оплате")
 d wx("K"_JJ,SU)
 S JJ=JJ+1
 Q
pdeA 
 d wx("B"_JJ,"Всего к оплате")
 d wx("K"_JJ,SU)
 S JJ=JJ+1
 d wx("B"_JJ,"Оплата от пациента")
 d wx("K"_JJ,0)
 S JJ=JJ+1
 d wx("B"_JJ,"ИТОГО к оплате")
 d wx("K"_JJ,SU)
 S JJ=JJ+1
 Q
wx(C,X) 
 S REZ("sheets","sheet",C)=X
 Q
LXLSz(IDX) ; Выгрузка excel с номером зуба
 N fZZ s fZZ=1
 G LXLS+2
LXLS(IDX) ; Выгрузка excel
 N fZZ s fZZ=0
 N X,FYDOCS,DT,NI,U,UA,PNI,A,W,VR,OT,SP,IDX,SU,CU,SUA,CUA,TIT,NDS,NND,DGN,CNT,CEN
 N fD,fS,fC,D1,D2,Pll,UN,K,FLG,prpF,diaK,DIA,CNA,PIDX,ZZ,wrkK,Z,PRC,aPRC,PLS
 N vrK,fioK,ocdiK,GRN,RS,RSS,DDS,DDE
 G LXLS1
 G:'$$CHECK^YDOCS(IDX) LPEXEND
 S FLG="|"_$$GET^YDOCS(IDX,"scflg")_"|",(fD,fS)=0
 S:FLG["|nodt|" fD=1 S:FLG["|nocen|" fS=1
 S fC=+$G(^cfg("nccst","cenn"))
 S prpF=$S(FLG["|prplst|":1,FLG["|prplstf|":2,1:0)
 
 S DGN=+$$GET^YDOCS(IDX,"dog"),D1=+$$GET^YDOCS(IDX,"date")
 S RSS=+$$GET^YDOCS(IDX,"rscsumm")
 S DDS=+$$GET^YDOCS(IDX,"df"),DDE=+$$GET^YDOCS(IDX,"dt")
 S K=$$GET^IINSC(DGN,"pccst",D1)
 
 D OWF^RWU(".txt")
 S SCNUM=$$GET^YDOCS(IDX,"scsnum")
 S SCDATE=$$DT^DTUTL($$GET^YDOCS(IDX,"scdate"))
 
 S A=$G(^cfg("nccst","scnuml")) S:'A A=6
 
 D WC^RWU(CR_"Приложение к Акту к счету № 1/00-"_$TR($J(SCNUM,A)," ",0)_" от "_SCDATE)
 D WC^RWU(CR_"о выполнении работ оказанных за период с "_$$DT^DTUTL(DDS)_" по "_$$DT^DTUTL(DDE))
 D WC^RWU(CR_"Заказчик/страховщик "_$$NAME^IINSC(DGN))
 D WC^RWU(CR_"код договора "_$$GET^IINSC(DGN,"dognum",+$H)_CR)
 
 S:K'="" K="|"_$$GETPL^ISPRAV("patccst",K,"cfg")_"|"
 S diaK=$S(K["|diagcode|":1,1:+$G(^cfg("ccst","diagcode"))) ; раздельно код и диагноз
 S vrK=$S(K["|vrcode|":1,1:+$G(^cfg("ccst","vrcode"))) ; выводить только код врача
 s wrkK=$S(K'["|nowork|":1,1:'+$G(^cfg("ccst","nowork"))) ; не указ. место работы
 S aPRC=$S(K["|expprc|":1,1:+$G(^cfg("ccst","expprc"))) ; выводить прейскурант
 S fioK=$S(K["|fullfio|":1,1:+$G(^cfg("ccst","fullfio"))) ; полное ФИО
 S ocdiK=$S(K["|onlydcode|":1,1:+$G(^cfg("ccst","onlydcode"))) ; Только коды диагнозов
 
 S ZZ=$$GET^YDOCS(IDX,"nzub")
 N WW
 S WW="17|20|45|30|25|80|10|22|22"
 D WC^RWU(CR_CR_"Дата|Карта|Ф.И.О.|Полис|Код|Услуга|К-во|Цена|Стоимость")
 D ORSTR^YDOCS
 S PNI="",(NDS,Pll,SUA,CUA,SU,CU)=0
 F  S X=$$RSTR^YDOCS(IDX) Q:FYDOCS=""  D
 .Q:$P(X,"|",5)=""  ; todo - не должно быть нулевых
 .S DT=$P(X,"|",1),NI=$P(X,"|",5),U=$P(X,"|",6),VR=$P(X,"|",2)
 .S OT=$P(X,"|",8),SP=$P(X,"|",11),IDX=$P(X,"|",9)
 .S GRN=$P(X,"|",13)
 .S:DT="p" DT=+$H,Pll=1
 .I PNI'=NI D
 ..I PNI'="" D WC^RWU(CR_"ИТОГО|по|"_$$FIOSH^IPAC(PNI)_"||||||"_$TR(SU,".",",")) S PNI="" S PNI=""
 ..S (SU,CU)=0
 .S PIDX=$$PIDXN^IPAC(NI,DGN,DT)
 .;S CNA=$S($D(^CNAD(DGN,U)):^(U),$D(^CNAD("*",U)):^(U),1:"")
 .;S UA=$S($P(CNA,"|",1)'="":$P(CNA,"|",1),1:U) ; псевдоним
 .S CNT=$P(X,"|",7),CEN=$P(X,"|",8)
 .;S A=$S(fS:"",1:$S(fC:CEN_"|",1:"")_(CNT*CEN)_"|")_$S(RSS:(CNT*$P(X,"|",14))_"|",1:"")
 .S:Pll D1=$P(U,",",1),D2=$P(U,",",2),K=$P(U,",",3)
 .S PRC=$P(X,"|",10)
 .S DIA=$E($P(X,"|",9),1,64),Z=DIA
 .S Z=$$DT2^DTUTL(DT)_"|"
 .S Z=Z_NI_"|"_$$FIOSH^IPAC(NI,DT)_"|"_$$GET^IPAC(NI,"polis"_PIDX,DT)_"|"
 .S UU=$$GET^IPRICE(U,"ecode",PRC,DT) S:UU="" UU=U
 .S UU=$P(UU,".",1)_"_"_$P(UU,".",2,99)
 .S NM=$G(^CNRESO(U)) ; TODO move->^CNAD
 .S:NM="" NM=$$NAMEH^IPRICE(U,PRC,DT)
 .S Z=Z_UU_"|"_NM_"|"
 .S PNI=NI,SU=CEN*CNT+SU,CU=CU+CNT
 .S SUA=CEN*CNT+SUA,CUA=CUA+CNT
 .Q:CEN=0  
 .S Z=Z_$TR(CNT_"|"_CEN_"|"_(CEN*CNT),".",",")
 .D WC^RWU(CR_Z) ; ,"1.5f"
 .;Q:Pll
 .S NND=$$GET^IPRICE(U,"nds",PRC,DT) Q:NND=""
 .S NDS=CEN*CNT*100/NND+NDS
 .S NDS=CEN*CNT*100/NND+NDS
 I PNI'="" D WC^RWU(CR_"ИТОГО|по|"_$$FIOSH^IPAC(PNI)_"||||||"_$TR(SU,".",",")) S PNI=""
 D WC^RWU(CR_"ВСЕГО: "_SUA_" руб.")
 D:NDS WC^RWU(CR_"В том числе НДС: "_NDS_" руб.")
 D WC^RWU(CR_CR_"От Исполнителя")
 ; D WC^RWU(CR_CR_"Заместитель главного врача _______________(О.А. Гущина)")
 ; D WC^RWU(CR_CR_"Заместитель главного бухгалтера _______________(Е.С. Бунеева)") TODO
LEEXEND 
 D C^RWU
