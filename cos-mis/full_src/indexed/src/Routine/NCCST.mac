 D WC^RWU(CR_CR_"Дата|Кол-во|Код|Сумма|Наименование услуг|Специалист")
 D WC^RWU(CR_"|услуг|услуги|||")
 D ORSTR^YDOCS
 S PNI="",(NDS,Pll,SUA,CUA,SU,CU)=0
 F  S X=$$RSTR^YDOCS(IDX) Q:FYDOCS=""  D
 .Q:$P(X,"|",5)=""  ; todo - не должно быть нулевых
 .S DT=$P(X,"|",1),NI=$P(X,"|",5),U=$P(X,"|",6),VR=$P(X,"|",2)
 .S GRN=$P(X,"|",13)
 .S:DT="p" DT=+$H,Pll=1
 .I PNI'=NI D
