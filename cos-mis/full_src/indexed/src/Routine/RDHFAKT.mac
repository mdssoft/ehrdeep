 ; <table width="100%" border="0" class="s1">
 ; <tr><td>Отчет по выполненным услугам - за период</td><td><div align="right">
RPUH2 
 ; <table width="100%" border="1" cellspacing="0"><tr class="s2" bgcolor="#CCCCCC">
RPUH3 
 ; <tr class="s2" bgcolor="#CCCCCC"><td>абсолют.</td><td>относит.</td></tr>
RPUT1 
 ; <html><head>
 ; <title>Отчет по типам оказания услуг</title>
 ; <meta http-equiv="Content-Type" content="text/html; charset=windows-1251">
 ; <style type="text/css">
 ; <!--
 ; .s1{  font-family: "Times New Roman", Times, serif; font-size: 22px; font-weight: bold}
 ; .s2 {  font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: bold; text-align: center}
 ; .s3 {  font-family: Arial, Helvetica, sans-serif; font-size: 12px; text-align: center}
 ; .s4 {  font-style: italic; font-weight: bold; text-align: right}
 ; .s5 {  font-style: italic; font-weight: none; text-align: right}
 ; .s6 {  text-align: right }
 ; .s7 {  font-style: italic; font-weight: none; text-align: right; font-size: 10px }
 ; -->
 ; </style>
 ; </head>
 ; <body bgcolor="#FFFFFF" text="#000000">
 ; <table width="100%" border="0" class="s1">
 ; <tr><td>Отчет по типам оказания услуг - за период</td><td><div align="right">
RPUT2 
 ; <table width="100%" border="1" cellspacing="0"><tr class="s2" bgcolor="#CCCCCC">
RPUT3 
 ; <tr class="s2" bgcolor="#CCCCCC"><td rowspan="2">Филиал, тип договора</td><td rowspan="2" width="18%">Выполненные по договору</td><td colspan="2">Кассовые</td></tr><tr class="s2" bgcolor="#CCCCCC"><td width="18%">фактически</td><td width="18%">обеспеченные средствами</td></tr>
MKULST(DS,DE,XI,NOKSS,TYPE) ; Type: 0-by type, 1-by DGN name
 N DGTPS,NMPROC
 S NMPROC=$S(+$G(TYPE)=0:"USLPROC^RDHFAKT",+$G(TYPE)=2:"USLPROC3^RDHFAKT",1:"USLPROC2^RDHFAKT")
 D MKALLPRC^IUSLSC(DS,DE,1,NMPROC,"",'+$$FR^I(),,1)
 ; Fill zeros:
 I $G(TYPE)=1 S LP="" F  S LP=$O(SSTAT(LP)) Q:LP=""  S X1="" F  S X1=$O(SSTAT(LP,XI,X1)) Q:X1=""  S X2="" F  S X2=$O(^DGN(X2)) Q:X2=""  S:+$G(SSTAT(LP,XI,X1,X2))=0 SSTAT(LP,XI,X1,X2)=0
 
 S LP="" F  S LP=$O(SSTAT(LP)) Q:LP=""  S X1="" F  S X1=$O(SSTAT(LP,XI,X1)) Q:X1=""  S X2="" F  S X2=$O(SSTAT(LP,XI,X1,X2)) Q:X2=""  D
 .S L=+$G(SSTAT(LP,XI,X1,X2))
 .S SSTAT(LP,XI,X1)=$G(SSTAT(LP,XI,X1))+L,SSTAT(LP,XI)=$G(SSTAT(LP,XI))+L
 .S SS(XI,X1,X2)=$G(SS(XI,X1,X2))+L,SS(XI,X1)=$G(SS(XI,X1))+L
 .S SS(XI)=$G(SS(XI))+L
 Q
USLPROC ; for callback IUSLSC
 I $G(NOKSS),STAT=2 Q 
 N TP,K,L,X S TP=$G(DGTPS(+CSTC,DT))
 I TP="" D  S DGTPS(+CSTC,DT)=TP
 .I $D(^BTPLS("stc",+CSTC)) S TP=2 Q
 .S K=$$GET^YNDOG(+CSTC,"dvid",DT) ; todo - timeline
 .I K=0!(K=1) S TP=3 Q 
 .I K=2!(K=4) S TP=4 Q 
 .I K=6 S TP=5 Q ; OMC
 .S TP=1 
 S X=$S(SUMM="":$$PRICEH^IPRICE(U,PRC,DT)*KSKD,1:SUMM)*$G(UL(U))
 S K=1,L=+$G(LPU)
 S:$D(STOTD(+OTD)) K=2
 S:$D(STAC(+OTD)) K=3
 S SSTAT(L,XI,K,TP)=$G(SSTAT(L,XI,K,TP))+X
 Q
USLPROC3 ; for callback IUSLSC - TPU
 I $G(NOKSS),STAT=2 Q 
 N TP,K,L,X S TP=$G(DGTPS(+CSTC,DT))
 I TP="" D  S DGTPS(+CSTC,DT)=TP
 .I $D(^BTPLS("stc",+CSTC)) S TP=2 Q
 .S K=$$GET^YNDOG(+CSTC,"dvid",DT) ; todo - timeline
 .I K=0 S TP=3 Q 
 .I K=1 S TP=4 Q
 .I K=2!(K=4) S TP=5 Q 
 .I K=6 S TP=6 Q ; OMC
 .S TP=1 
 S X=$S(SUMM="":$$PRICEH^IPRICE(U,PRC,DT)*KSKD,1:SUMM)*$G(UL(U))
 S K=1,L=+$G(LPU)
 S:$D(STOTD(+OTD)) K=2
 S:$D(STAC(+OTD)) K=3
 S SSTAT(L,XI,K,TP)=$G(SSTAT(L,XI,K,TP))+X
 Q
USLPROC2 ; for callback IUSLSC, by DGN
 I $G(NOKSS),STAT=2 Q 
 N K,L,X
 S X=$S(SUMM="":$$PRICEH^IPRICE(U,PRC,DT)*KSKD,1:SUMM)*$G(UL(U))
 S K=1,L=+$G(LPU)
 S:$D(STOTD(+OTD)) K=2
 S:$D(STAC(+OTD)) K=3
 S SSTAT(L,XI,K,+CSTC)=$G(SSTAT(L,XI,K,+CSTC))+X
 Q
USLERRP ; for callback IUSLSC
 Q
FFN(X) 
 Q $TR($TR($FN(X,",",2),","," "),".",",")
FFN1(X) 
 Q $TR($TR($FN(X,",",1),","," "),".",",")
REGIPROC 
 ; Q:+$$FR^I()=0
 N D S D="Общие отчеты"
 S ^IPROC(D,"Отчет по выполненным услугам за период")="RPU_RDHFAKT,3,2,d,Начальная дата отчета,d,Конечная дата отчета"
 S ^IPROC(D,"Таблица по выполненным услугам за период")="RPUT_RDHFAKT,1,2,d,Начальная дата отчета,d,Конечная дата отчета"
 S ^IPROC(D,"Выполненные услуги по договорам за период")="RPUDG_RDHFAKT,3,2,d,Начальная дата отчета,d,Конечная дата отчета"
 S ^IPROC(D,"Отчет по типам оказания услуг за период")="TPU_RDHFAKT,3,2,d,Начальная дата отчета,d,Конечная дата отчета"
 S ^IPROC(D,"Таблица по типам оказания услуг за период")="TPUT_RDHFAKT,1,2,d,Начальная дата отчета,d,Конечная дата отчета"
 Q
 
